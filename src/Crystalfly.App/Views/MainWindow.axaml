<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Crystalfly.App.ViewModels"
        xmlns:models="using:Crystalfly.Core.Models"
        xmlns:mv="using:MarkView.Avalonia"
        xmlns:converters="using:Avalonia.Data.Converters"
        xmlns:u="https://irihi.tech/ursa"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1100"
        d:DesignHeight="720"
        x:Class="Crystalfly.App.Views.MainWindow"
        x:Name="Root"
        x:DataType="vm:MainViewModel"
        Classes="cfp-window"
        Width="1100"
        Height="720"
        MinWidth="900"
        MinHeight="600"
        CanResize="True"
        WindowDecorations="BorderOnly"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"
        Icon="/Assets/hollow-knight-icon.png"
        Title="Crystalfly">

    <Window.Resources>
        <x:Int32 x:Key="Zero">0</x:Int32>
    </Window.Resources>

    <Design.DataContext>
        <vm:MainViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,*">
        <Border Grid.Row="0"
                Classes="cfp-topbar"
                PointerPressed="OnWindowChromePointerPressed">
            <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="24">
                <TextBlock Grid.Column="0" Classes="cfp-brand" Text="Crystalfly" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="4"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsEnabled="{Binding CanNavigate}">
                    <Button Classes="cfp-nav"
                            Classes.active="{Binding IsLaunchPage}"
                            Command="{Binding SelectPageCommand}"
                            CommandParameter="Launch">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <LucideIcon Kind="Power" Size="16" />
                            <TextBlock Text="{Binding Loc[NavLaunch]}" />
                        </StackPanel>
                    </Button>
                    <Button Classes="cfp-nav"
                            Classes.active="{Binding IsSpeedrunPage}"
                            Command="{Binding SelectPageCommand}"
                            CommandParameter="Speedrun">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <LucideIcon Kind="Timer" Size="16" />
                            <TextBlock Text="{Binding Loc[NavSpeedrun]}" />
                        </StackPanel>
                    </Button>
                    <Button Classes="cfp-nav"
                            Classes.active="{Binding IsDownloadsPage}"
                            Command="{Binding SelectPageCommand}"
                            CommandParameter="Downloads">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <LucideIcon Kind="Download" Size="16" />
                            <TextBlock Text="{Binding Loc[NavDownloads]}" />
                        </StackPanel>
                    </Button>
                    <Button Classes="cfp-nav"
                            Classes.active="{Binding IsSettingsPage}"
                            Command="{Binding SelectPageCommand}"
                            CommandParameter="Settings">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <LucideIcon Kind="Settings" Size="16" />
                            <TextBlock Text="{Binding Loc[NavSettings]}" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="4"
                            HorizontalAlignment="Right">
                    <Button Classes="cfp-window-button cfp-window-minimize"
                            Click="OnWindowMinimizeClick"
                            ToolTip.Tip="{Binding Loc[WindowMinimize]}"
                            AutomationProperties.Name="{Binding Loc[WindowMinimize]}"
                            Content="{LucideIconContent Minus, 16}" />
                    <Button Classes="cfp-window-button cfp-window-maximize"
                            Click="OnWindowMaximizeClick"
                            ToolTip.Tip="{Binding Loc[WindowMaximize]}"
                            AutomationProperties.Name="{Binding Loc[WindowMaximize]}"
                            Content="{LucideIconContent Maximize2, 16}" />
                    <Button Classes="cfp-window-button cfp-window-close"
                            Click="OnWindowCloseClick"
                            ToolTip.Tip="{Binding Loc[WindowClose]}"
                            AutomationProperties.Name="{Binding Loc[WindowClose]}"
                            Content="{LucideIconContent X, 16}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Classes="cfp-error"
                IsVisible="{Binding ErrorMessage, Converter={x:Static converters:StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource CfErrorBrush}"
                       TextWrapping="Wrap" />
        </Border>

        <u:LoadingContainer Name="GlobalLoadingHost"
                            Grid.Row="2"
                            IsLoading="{Binding IsBusy}"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch">
            <u:LoadingContainer.Indicator>
                <Grid Width="360" Height="112" RowDefinitions="20,72,20">
                    <Border Name="GlobalKnightLoadingViewport"
                            Grid.Row="1"
                            Width="45"
                            Height="72"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            ClipToBounds="True">
                        <Image Name="GlobalKnightWalkImage"
                               Width="180"
                               Height="72"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               Source="/Assets/knight-walk.png" />
                    </Border>
                    <TextBlock Name="GlobalLoadingMessage"
                               Grid.Row="2"
                               Classes="cfp-meta"
                               Text="{Binding StatusMessage}"
                               TextAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                </Grid>
            </u:LoadingContainer.Indicator>
        <Grid>
            <!-- Launch -->
            <Grid Classes="cfp-page" IsVisible="{Binding IsLaunchPage}" ColumnDefinitions="224,*">
                <Border Grid.ColumnSpan="2"
                        Classes="cfp-launch-issue-frame"
                        IsHitTestVisible="False"
                        IsVisible="{Binding HasLaunchIssues}"
                        ZIndex="100" />
                <Border Grid.Column="0" Classes="cfp-rail" Padding="16">
                    <Grid RowDefinitions="Auto,*,Auto">
                        <StackPanel Grid.Row="0" Spacing="12" HorizontalAlignment="Stretch">
                            <Image Width="64"
                                   Height="64"
                                   HorizontalAlignment="Center"
                                   Source="/Assets/knight-icon.png" />
                            <StackPanel Spacing="4" HorizontalAlignment="Center">
                                <TextBlock Classes="cfp-page-title"
                                           Text="{Binding SelectedInstance.Name}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap" />
                                <TextBlock Classes="cfp-meta"
                                           Text="{Binding SelectedInstance.DisplayVersion}"
                                           TextAlignment="Center" />
                            </StackPanel>
                            <Border Classes="cfp-badge" HorizontalAlignment="Center" IsVisible="{Binding HasInstance}">
                                <TextBlock Text="{Binding SelectedInstance.LoaderDisplay}"
                                           Foreground="{DynamicResource CfAccentTextBrush}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           MaxWidth="184"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap" />
                            </Border>
                            <TextBlock Classes="cfp-meta"
                                       Text="{Binding Loc[NoInstance]}"
                                       TextAlignment="Center"
                                       IsVisible="{Binding HasInstance, Converter={x:Static converters:BoolConverters.Not}}" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Spacing="8">
                            <Button Classes="cfp-primary"
                                     HorizontalAlignment="Stretch"
                                     HorizontalContentAlignment="Center"
                                     Click="ConfirmLaunch"
                                     IsEnabled="{Binding CanAttemptLaunch}">
                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                    <LucideIcon Kind="Play" Size="16" />
                                    <TextBlock Text="{Binding Loc[LaunchGame]}" />
                                </StackPanel>
                            </Button>
                            <Button Classes="cfp-secondary"
                                      MinHeight="40"
                                      HorizontalAlignment="Stretch"
                                      HorizontalContentAlignment="Center"
                                      Command="{Binding SelectPageCommand}"
                                      CommandParameter="Versions"
                                      Content="{Binding Loc[SelectInstance]}" />
                            <Button Classes="cfp-secondary"
                                    MinHeight="40"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    Command="{Binding OpenInstanceSettingsCommand}"
                                    CommandParameter="{Binding SelectedInstance}"
                                    IsEnabled="{Binding HasInstance}">
                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                    <LucideIcon Kind="Settings" Size="16" />
                                    <TextBlock Text="{Binding Loc[ManageInstance]}" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Column="1"
                              HorizontalContentAlignment="Stretch"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Classes="cfp-workspace"
                                Margin="32,24"
                                Spacing="16"
                                MaxWidth="1920"
                                HorizontalAlignment="Stretch">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Classes="cfp-page-title" Text="{Binding LaunchReadinessTitle}" />
                                <TextBlock Classes="cfp-meta" Text="{Binding LaunchReadinessHint}" TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <Button Classes="cfp-secondary"
                                        Click="ShowLaunchIssues"
                                        IsVisible="{Binding HasLaunchIssues}"
                                        AutomationProperties.Name="{Binding Loc[LaunchIssues]}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <LucideIcon Kind="TriangleAlert" Size="15" Foreground="{DynamicResource CfErrorBrush}" />
                                        <TextBlock Text="{Binding LaunchIssueCountText}"
                                                   Foreground="{DynamicResource CfErrorBrush}"
                                                   FontWeight="SemiBold" />
                                    </StackPanel>
                                </Button>
                                <Border Classes="cfp-badge">
                                    <TextBlock Text="{Binding StatusMessage}"
                                               Foreground="{DynamicResource CfAccentTextBrush}"
                                               FontSize="13"
                                               FontWeight="SemiBold" />
                                </Border>
                            </StackPanel>
                        </Grid>

                        <u:Skeleton IsLoading="{Binding IsLoadingInstanceDetails}"
                                    IsActive="{Binding IsLoadingInstanceDetails}">
                        <Border Classes="cfp-card" IsVisible="{Binding HasInstance}">
                            <StackPanel Spacing="16">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <TextBlock Classes="cfp-section-title" Text="{Binding SelectedInstance.Name}" />
                                        <TextBlock Classes="cfp-meta" Text="{Binding SelectedInstance.RootPath}" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Classes="cfp-secondary"
                                            Click="ShowLaunchIssues"
                                            IsVisible="{Binding HasLaunchIssues}"
                                            Content="{Binding Loc[ViewDetails]}" />
                                </Grid>

                                <WrapPanel Orientation="Horizontal">
                                    <TextBlock Classes="cfp-row-title" Text="{Binding SelectedInstance.DisplayVersion}" />
                                    <TextBlock Margin="8,0" Text="·" />
                                    <TextBlock Text="{Binding SelectedInstance.LoaderDisplay}" TextWrapping="Wrap" />
                                    <TextBlock Margin="8,0" Text="·" />
                                    <TextBlock Margin="0,0,8,0" Text="{Binding SelectedInstance.ModCount}" />
                                    <TextBlock Text="Mods" />
                                </WrapPanel>

                                <StackPanel>
                                    <Border Classes="cfp-divider-row">
                                        <Grid ColumnDefinitions="20,*,Auto" ColumnSpacing="8">
                                            <Grid Grid.Column="0">
                                                <LucideIcon Kind="CircleCheck" Size="16" IsVisible="{Binding LaunchPreflight.GameFilesReady}" />
                                                <LucideIcon Kind="TriangleAlert" Size="16" Foreground="{DynamicResource CfErrorBrush}"
                                                            IsVisible="{Binding LaunchPreflight.GameFilesReady, Converter={x:Static converters:BoolConverters.Not}}" />
                                            </Grid>
                                            <TextBlock Grid.Column="1" Text="{Binding Loc[GameFiles]}" FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="2" Classes="cfp-meta" Text="{Binding GameFilesStatus}" />
                                        </Grid>
                                    </Border>
                                    <Border Classes="cfp-divider-row">
                                        <Grid ColumnDefinitions="20,*,Auto" ColumnSpacing="8">
                                            <Grid Grid.Column="0">
                                                <LucideIcon Kind="CircleCheck" Size="16" IsVisible="{Binding LaunchPreflight.LoaderReady}" />
                                                <LucideIcon Kind="TriangleAlert" Size="16" Foreground="{DynamicResource CfErrorBrush}"
                                                            IsVisible="{Binding LaunchPreflight.LoaderReady, Converter={x:Static converters:BoolConverters.Not}}" />
                                            </Grid>
                                            <TextBlock Grid.Column="1" Text="{Binding Loc[LoaderStatus]}" FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="2" Classes="cfp-meta" Text="{Binding LoaderPreflightStatus}" />
                                        </Grid>
                                    </Border>
                                    <Border Classes="cfp-divider-row">
                                        <Grid ColumnDefinitions="20,*,Auto" ColumnSpacing="8">
                                            <Grid Grid.Column="0">
                                                <LucideIcon Kind="CircleCheck" Size="16" IsVisible="{Binding LaunchPreflight.DependenciesReady}" />
                                                <LucideIcon Kind="TriangleAlert" Size="16" Foreground="{DynamicResource CfErrorBrush}"
                                                            IsVisible="{Binding LaunchPreflight.DependenciesReady, Converter={x:Static converters:BoolConverters.Not}}" />
                                            </Grid>
                                            <TextBlock Grid.Column="1" Text="{Binding Loc[ModDependencies]}" FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="2" Classes="cfp-meta" Text="{Binding ModDependencyStatus}" />
                                        </Grid>
                                    </Border>
                                    <Border Padding="12,10">
                                        <Grid ColumnDefinitions="20,*,Auto" ColumnSpacing="8">
                                            <Grid Grid.Column="0">
                                                <LucideIcon Kind="CircleCheck" Size="16" IsVisible="{Binding LaunchPreflight.SaveIsolationReady}" />
                                                <LucideIcon Kind="TriangleAlert" Size="16" Foreground="{DynamicResource CfErrorBrush}"
                                                            IsVisible="{Binding LaunchPreflight.SaveIsolationReady, Converter={x:Static converters:BoolConverters.Not}}" />
                                            </Grid>
                                            <TextBlock Grid.Column="1" Text="{Binding Loc[SaveIsolation]}" FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="2" Classes="cfp-meta" Text="{Binding SaveIsolationStatus}" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        </u:Skeleton>

                        <TextBlock Classes="cfp-meta"
                                   Text="{Binding Loc[ChooseRoot]}"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding HasInstance, Converter={x:Static converters:BoolConverters.Not}}" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Versions -->
            <Grid Classes="cfp-page" IsVisible="{Binding IsVersionsPage}">
                <ScrollViewer HorizontalContentAlignment="Stretch"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Classes="cfp-workspace"
                                Margin="24"
                                Spacing="16"
                                MaxWidth="1920"
                                HorizontalAlignment="Stretch">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                            <StackPanel Spacing="4">
                                <TextBlock Classes="cfp-section-title" Text="{Binding Loc[SelectInstance]}" />
                                <TextBlock Classes="cfp-meta" Text="{Binding Loc[InstancesHint]}" TextWrapping="Wrap" />
                            </StackPanel>
                            <Button Grid.Column="1" Classes="cfp-secondary" Command="{Binding RefreshCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <LucideIcon Kind="RefreshCw" Size="16" />
                                    <TextBlock Text="{Binding Loc[Refresh]}" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <TextBox Classes="cfp-input"
                                 Text="{Binding SearchText, Mode=TwoWay}"
                                 PlaceholderText="{Binding Loc[SearchInstances]}"
                                 AutomationProperties.Name="{Binding Loc[SearchInstances]}" />

                        <Border Classes="cfp-list-frame">
                            <Grid>
                                <ListBox Classes="cfp-list cfp-instance-list"
                                         ItemsSource="{Binding VisibleInstances}"
                                         SelectedItem="{Binding SelectedInstance, Mode=TwoWay}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:InstanceItemViewModel">
                                            <Grid Classes="cfp-instance-row"
                                                  ColumnDefinitions="*,Auto"
                                                  ColumnSpacing="8"
                                                  HorizontalAlignment="Stretch">
                                                <Button Grid.ColumnSpan="2"
                                                        Classes="cfp-instance-main"
                                                        Command="{Binding #Root.DataContext.SelectInstanceForLaunchCommand}"
                                                        CommandParameter="{Binding}"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Stretch" />
                                                <Grid Grid.Column="0"
                                                      Classes="cfp-instance-summary"
                                                      ColumnDefinitions="44,*"
                                                      ColumnSpacing="12"
                                                      HorizontalAlignment="Left"
                                                      IsHitTestVisible="False">
                                                    <Border Width="40" Height="40" CornerRadius="6"
                                                            Background="{DynamicResource CfSurfaceHoverBrush}">
                                                        <LucideIcon Kind="Box" Size="18"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center" />
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                                        <TextBlock Classes="cfp-row-title" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                                        <WrapPanel Orientation="Horizontal">
                                                            <TextBlock Classes="cfp-meta" Text="{Binding DisplayVersion}" />
                                                            <TextBlock Classes="cfp-meta" Margin="8,0" Text="{Binding LoaderDisplay}" TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Classes="cfp-meta" Margin="0,0,4,0" Text="{Binding ModCount}" />
                                                            <TextBlock Classes="cfp-meta" Text="Mods" />
                                                        </WrapPanel>
                                                    </StackPanel>
                                                </Grid>
                                                <StackPanel Grid.Column="1"
                                                            Classes="cfp-instance-actions"
                                                            Orientation="Horizontal"
                                                            Spacing="2"
                                                            Width="94"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Center">
                                                    <Button Classes="cfp-instance-action"
                                                            Click="ConfirmDeleteInstance"
                                                            ToolTip.Tip="{Binding #Root.DataContext.Loc[DeleteInstance]}"
                                                            AutomationProperties.Name="{Binding #Root.DataContext.Loc[DeleteInstance]}"
                                                            Content="{LucideIconContent Trash2, 15}" />
                                                    <Button Classes="cfp-instance-action"
                                                            Click="CloneInstanceWithName"
                                                            ToolTip.Tip="{Binding #Root.DataContext.Loc[CloneInstance]}"
                                                            AutomationProperties.Name="{Binding #Root.DataContext.Loc[CloneInstance]}"
                                                            Content="{LucideIconContent Copy, 15}" />
                                                    <Button Classes="cfp-instance-action"
                                                            Command="{Binding #Root.DataContext.OpenInstanceSettingsCommand}"
                                                            CommandParameter="{Binding}"
                                                            ToolTip.Tip="{Binding #Root.DataContext.Loc[ManageInstance]}"
                                                            AutomationProperties.Name="{Binding #Root.DataContext.Loc[ManageInstance]}"
                                                            Content="{LucideIconContent Settings, 15}" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <StackPanel MinHeight="120" Margin="24" Spacing="12"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            IsVisible="{Binding VisibleInstances.Count, Converter={x:Static converters:ObjectConverters.Equal}, ConverterParameter={StaticResource Zero}}">
                                    <TextBlock Classes="cfp-meta" Text="{Binding Loc[NoInstancesAction]}"
                                               TextAlignment="Center" TextWrapping="Wrap" />
                                    <Button Classes="cfp-secondary" Command="{Binding SelectPageCommand}" CommandParameter="Settings">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <LucideIcon Kind="Settings" Size="16" />
                                            <TextBlock Text="{Binding Loc[OpenSettings]}" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Instance management -->
            <Grid Classes="cfp-page" IsVisible="{Binding IsManagePage}">
                <Grid ColumnDefinitions="176,*">
                    <Border Grid.Column="0" Classes="cfp-rail" Padding="12,16">
                        <StackPanel Classes="cfp-manage-nav" Spacing="4" IsEnabled="{Binding CanNavigate}">
                            <Button Classes="cfp-local-nav"
                                    Classes.active="{Binding CurrentManageTab, Converter={x:Static converters:ObjectConverters.Equal}, ConverterParameter=Overview}"
                                    Command="{Binding SelectManageTabCommand}"
                                    CommandParameter="Overview">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8"><LucideIcon Kind="Box" Size="16" /><TextBlock Grid.Column="1" Text="{Binding Loc[Overview]}" TextTrimming="CharacterEllipsis" /></Grid>
                            </Button>
                            <Button Classes="cfp-local-nav"
                                    Classes.active="{Binding CurrentManageTab, Converter={x:Static converters:ObjectConverters.Equal}, ConverterParameter=Loader}"
                                    Command="{Binding SelectManageTabCommand}"
                                    CommandParameter="Loader">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8"><LucideIcon Kind="Wrench" Size="16" /><TextBlock Grid.Column="1" Text="{Binding Loc[Loader]}" TextTrimming="CharacterEllipsis" /></Grid>
                            </Button>
                            <Button Classes="cfp-local-nav"
                                    Classes.active="{Binding CurrentManageTab, Converter={x:Static converters:ObjectConverters.Equal}, ConverterParameter=Mods}"
                                    Command="{Binding SelectManageTabCommand}"
                                    CommandParameter="Mods">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8"><LucideIcon Kind="PackagePlus" Size="16" /><TextBlock Grid.Column="1" Text="{Binding Loc[Mods]}" TextTrimming="CharacterEllipsis" /></Grid>
                            </Button>
                            <Button Classes="cfp-local-nav"
                                    Classes.active="{Binding CurrentManageTab, Converter={x:Static converters:ObjectConverters.Equal}, ConverterParameter=Presets}"
                                    Command="{Binding SelectManageTabCommand}"
                                    CommandParameter="Presets">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8"><LucideIcon Kind="ListRestart" Size="16" /><TextBlock Grid.Column="1" Text="{Binding Loc[ModPresets]}" TextTrimming="CharacterEllipsis" /></Grid>
                            </Button>
                            <Button Classes="cfp-local-nav"
                                    Classes.active="{Binding CurrentManageTab, Converter={x:Static converters:ObjectConverters.Equal}, ConverterParameter=Snapshots}"
                                    Command="{Binding SelectManageTabCommand}"
                                    CommandParameter="Snapshots">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8"><LucideIcon Kind="Camera" Size="16" /><TextBlock Grid.Column="1" Text="{Binding Loc[Snapshots]}" TextTrimming="CharacterEllipsis" /></Grid>
                            </Button>
                            <Button Classes="cfp-local-nav"
                                    Classes.active="{Binding CurrentManageTab, Converter={x:Static converters:ObjectConverters.Equal}, ConverterParameter=Logs}"
                                    Command="{Binding SelectManageTabCommand}"
                                    CommandParameter="Logs">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8"><LucideIcon Kind="ScrollText" Size="16" /><TextBlock Grid.Column="1" Text="{Binding Loc[Logs]}" TextTrimming="CharacterEllipsis" /></Grid>
                            </Button>
                            <Button Classes="cfp-local-nav"
                                    Classes.active="{Binding CurrentManageTab, Converter={x:Static converters:ObjectConverters.Equal}, ConverterParameter=Config}"
                                    Command="{Binding SelectManageTabCommand}"
                                    CommandParameter="Config">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8"><LucideIcon Kind="Settings2" Size="16" /><TextBlock Grid.Column="1" Text="{Binding Loc[Config]}" TextTrimming="CharacterEllipsis" /></Grid>
                            </Button>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Column="1"
                                  HorizontalContentAlignment="Stretch"
                                  HorizontalScrollBarVisibility="Disabled">
                        <Grid Classes="cfp-workspace"
                              Margin="24"
                              MaxWidth="1920"
                              HorizontalAlignment="Stretch">
                            <StackPanel Spacing="16"
                                        Classes="cfp-tab-panel"
                                        IsVisible="{Binding CurrentManageTab, Converter={x:Static converters:ObjectConverters.Equal}, ConverterParameter=Overview}">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="cfp-page-title" Text="{Binding Loc[Overview]}" />
                                    <TextBlock Classes="cfp-meta" Text="{Binding SelectedInstance.RootPath}" TextWrapping="Wrap" />
                                </StackPanel>
                                <Border Classes="cfp-card">
                                    <StackPanel>
                                        <Border Classes="cfp-divider-row">
                                            <Grid ColumnDefinitions="*,Auto"><TextBlock Text="{Binding Loc[NavVersions]}" /><TextBlock Grid.Column="1" Text="{Binding SelectedInstance.DisplayVersion}" FontWeight="SemiBold" /></Grid>
                                        </Border>
                                        <Border Classes="cfp-divider-row">
                                            <Grid ColumnDefinitions="*,Auto"><TextBlock Text="{Binding Loc[Loader]}" /><TextBlock Grid.Column="1" Text="{Binding CurrentLoaderState}" FontWeight="SemiBold" /></Grid>
                                        </Border>
                                        <Border Padding="12,10">
                                            <Grid ColumnDefinitions="*,Auto"><TextBlock Text="{Binding Loc[Mods]}" /><TextBlock Grid.Column="1" Text="{Binding SelectedInstance.ModCount}" FontWeight="SemiBold" /></Grid>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Spacing="16"
                                        Classes="cfp-tab-panel"
                                        IsVisible="{Binding CurrentManageTab, Converter={x:Static converters:ObjectConverters.Equal}, ConverterParameter=Loader}">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="cfp-page-title" Text="{Binding Loc[Loader]}" />
                                    <TextBlock Classes="cfp-meta" Text="{Binding CurrentLoaderState}" TextWrapping="Wrap" />
                                    <TextBlock Classes="cfp-caption"
                                               Text="{Binding LoaderVerificationStatus}"
                                               TextWrapping="Wrap"
                                               IsVisible="{Binding LoaderVerificationStatus, Converter={x:Static converters:StringConverters.IsNotNullOrEmpty}}" />
                                </StackPanel>
                                <Border Classes="cfp-card">
                                    <StackPanel Spacing="12">
                                        <ComboBox Classes="cfp-input"
                                                  ItemsSource="{Binding AvailableLoaders}"
                                                  SelectedItem="{Binding SelectedLoader, Mode=TwoWay}"
                                                  HorizontalAlignment="Stretch"
                                                  AutomationProperties.Name="{Binding Loc[Loader]}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate x:DataType="models:LoaderManifest">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock Text="{Binding Name}" />
                                                        <TextBlock Classes="cfp-meta" Text="{Binding Version}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <StackPanel Spacing="8"
                                                    IsVisible="{Binding AvailableLoaders.Count, Converter={x:Static converters:ObjectConverters.Equal}, ConverterParameter={StaticResource Zero}}">
                                            <TextBlock Classes="cfp-meta"
                                                       Text="{Binding Loc[NoLoadersAction]}"
                                                       TextWrapping="Wrap" />
                                            <Button Classes="cfp-secondary"
                                                    Command="{Binding RefreshCommand}"
                                                    HorizontalAlignment="Left">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <LucideIcon Kind="RefreshCw" Size="16" />
                                                    <TextBlock Text="{Binding Loc[Refresh]}" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                        <WrapPanel Orientation="Horizontal">
                                            <Button Classes="cfp-accent"
                                                    Command="{Binding InstallOrSwitchLoaderCommand}"
                                                    Margin="0,0,8,8">
                                                <Button.IsEnabled>
                                                    <MultiBinding Converter="{x:Static converters:BoolConverters.And}">
                                                        <Binding Path="SelectedLoader" Converter="{x:Static converters:ObjectConverters.IsNotNull}" />
                                                        <Binding Path="IsBusy" Converter="{x:Static converters:BoolConverters.Not}" />
                                                        <Binding Path="IsGameRunning" Converter="{x:Static converters:BoolConverters.Not}" />
                                                    </MultiBinding>
                                                </Button.IsEnabled>
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <LucideIcon Kind="PackagePlus" Size="16" />
                                                    <TextBlock Text="{Binding Loc[InstallOrSwitch]}" />
                                                </StackPanel>
                                            </Button>
                                            <Button Classes="cfp-secondary"
                                                    Command="{Binding RepairLoaderCommand}"
                                                    Margin="0,0,8,8">
                                                <Button.IsEnabled>
                                                    <MultiBinding Converter="{x:Static converters:BoolConverters.And}">
                                                        <Binding Path="HasInstance" />
                                                        <Binding Path="IsBusy" Converter="{x:Static converters:BoolConverters.Not}" />
                                                        <Binding Path="IsGameRunning" Converter="{x:Static converters:BoolConverters.Not}" />
                                                    </MultiBinding>
                                                </Button.IsEnabled>
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <LucideIcon Kind="Wrench" Size="16" />
                                                    <TextBlock Text="{Binding Loc[Repair]}" />
                                                </StackPanel>
                                            </Button>
                                            <Button Classes="cfp-secondary"
                                                    Click="ConfirmUninstallLoader"
                                                    Margin="0,0,8,8">
                                                <Button.IsEnabled>
                                                    <MultiBinding Converter="{x:Static converters:BoolConverters.And}">
                                                        <Binding Path="HasInstance" />
                                                        <Binding Path="IsBusy" Converter="{x:Static converters:BoolConverters.Not}" />
                                                        <Binding Path="IsGameRunning" Converter="{x:Static converters:BoolConverters.Not}" />
                                                    </MultiBinding>
                                                </Button.IsEnabled>
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <LucideIcon Kind="Trash2" Size="16" />
                                                    <TextBlock Text="{Binding Loc[Uninstall]}" />
                                                </StackPanel>
                                            </Button>
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                                <Expander Header="{Binding Loc[AdvancedLocalLoader]}">
                                    <Border Classes="cfp-card" Margin="0,8,0,0">
                                        <StackPanel Spacing="10">
                                            <u:PathPicker UsePickerType="OpenFile"
                                                          FileFilter="[JSON,*.json]"
                                                          Title="{Binding Loc[SelectLoaderManifestTitle]}"
                                                          SelectedPathsText="{Binding LocalLoaderManifestPath, Mode=TwoWay}"
                                                          IsOmitCommandOnCancel="True"
                                                          MinHeight="44"
                                                          AutomationProperties.Name="{Binding Loc[LocalLoaderManifestPath]}">
                                                <u:PathPicker.Styles>
                                                    <Style Selector="TextBox">
                                                        <Setter Property="AutomationProperties.Name"
                                                                Value="{Binding Loc[LocalLoaderManifestPath]}" />
                                                    </Style>
                                                </u:PathPicker.Styles>
                                                <u:PathPicker.ButtonContent>
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <LucideIcon Kind="FolderOpen" Size="16" />
                                                        <TextBlock Text="{Binding Loc[Browse]}" />
                                                    </StackPanel>
                                                </u:PathPicker.ButtonContent>
                                            </u:PathPicker>
                                            <Button Classes="cfp-secondary"
                                                    Command="{Binding ImportLocalLoaderCommand}"
                                                    HorizontalAlignment="Left">
                                                <Button.IsEnabled>
                                                    <MultiBinding Converter="{x:Static converters:BoolConverters.And}">
                                                        <Binding Path="HasInstance" />
                                                        <Binding Path="LocalLoaderManifestPath" Converter="{x:Static converters:StringConverters.IsNotNullOrEmpty}" />
                                                        <Binding Path="IsBusy" Converter="{x:Static converters:BoolConverters.Not}" />
                                                        <Binding Path="IsGameRunning" Converter="{x:Static converters:BoolConverters.Not}" />
                                                    </MultiBinding>
                                                </Button.IsEnabled>
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <LucideIcon Kind="ShieldAlert" Size="16" />
                                                    <TextBlock Text="{Binding Loc[ImportLocalLoader]}" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </Expander>
                            </StackPanel>

                            <StackPanel Spacing="16"
                                        Classes="cfp-tab-panel"
                                        IsVisible="{Binding CurrentManageTab, Converter={x:Static converters:ObjectConverters.Equal}, ConverterParameter=Presets}">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="cfp-page-title" Text="{Binding Loc[ModPresets]}" />
                                        <TextBlock Classes="cfp-meta" Text="{Binding Loc[ModPresetsHint]}" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Classes="cfp-secondary"
                                            Command="{Binding RestorePresetStateCommand}"
                                            IsEnabled="{Binding HasPresetRestorePoint}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <LucideIcon Kind="Undo2" Size="16" />
                                            <TextBlock Text="{Binding Loc[RestorePresetState]}" />
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <Grid ColumnDefinitions="252,*" ColumnSpacing="16" MinHeight="380">
                                    <StackPanel Grid.Column="0" Spacing="12">
                                        <Border Classes="cfp-card">
                                            <StackPanel Spacing="10">
                                                <TextBox Classes="cfp-input"
                                                         Text="{Binding PresetName, Mode=TwoWay}"
                                                         PlaceholderText="{Binding Loc[PresetName]}"
                                                         AutomationProperties.Name="{Binding Loc[PresetName]}" />
                                                <ComboBox Classes="cfp-input"
                                                          ItemsSource="{Binding PresetModeOptions}"
                                                          SelectedItem="{Binding SelectedPresetModeOption, Mode=TwoWay}"
                                                          AutomationProperties.Name="{Binding Loc[PresetMode]}">
                                                    <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate>
                                                </ComboBox>
                                                <Button Classes="cfp-accent" Command="{Binding CreatePresetCommand}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <LucideIcon Kind="Plus" Size="16" />
                                                        <TextBlock Text="{Binding Loc[CreatePreset]}" />
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </Border>
                                        <Border Classes="cfp-list-frame">
                                            <Grid>
                                                <ListBox Classes="cfp-list cfp-preset-list"
                                                         MinHeight="220"
                                                         ItemsSource="{Binding ModPresets}"
                                                         SelectedItem="{Binding SelectedPreset, Mode=TwoWay}">
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate x:DataType="models:ModPreset">
                                                            <StackPanel Spacing="3">
                                                                <TextBlock Classes="cfp-row-title" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                                                <WrapPanel>
                                                                    <TextBlock Classes="cfp-caption" Text="{Binding ApplyMode}" />
                                                                    <TextBlock Classes="cfp-caption" Margin="8,0,0,0" Text="{Binding Entries.Count}" />
                                                                </WrapPanel>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                                <TextBlock Margin="20"
                                                           Classes="cfp-meta"
                                                           Text="{Binding Loc[NoPresetsAction]}"
                                                           TextWrapping="Wrap"
                                                           TextAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           IsVisible="{Binding ModPresets.Count, Converter={x:Static converters:ObjectConverters.Equal}, ConverterParameter={StaticResource Zero}}" />
                                            </Grid>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Spacing="12">
                                        <Border Classes="cfp-card" IsVisible="{Binding HasSelectedPreset}">
                                            <StackPanel Spacing="12">
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                    <StackPanel Spacing="3">
                                                        <TextBlock Classes="cfp-section-title" Text="{Binding SelectedPreset.Name}" TextTrimming="CharacterEllipsis" />
                                                        <WrapPanel>
                                                            <TextBlock Classes="cfp-meta" Text="{Binding SelectedPreset.GameBuildId}" />
                                                            <TextBlock Classes="cfp-meta" Margin="8,0,0,0" Text="{Binding SelectedPreset.LoaderId}" />
                                                        </WrapPanel>
                                                    </StackPanel>
                                                    <Button Grid.Column="1" Classes="cfp-accent" Click="ConfirmApplyPreset">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <LucideIcon Kind="Play" Size="16" />
                                                            <TextBlock Text="{Binding Loc[ApplyPreset]}" />
                                                        </StackPanel>
                                                    </Button>
                                                </Grid>
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                    <TextBox Classes="cfp-input"
                                                             Text="{Binding PresetName, Mode=TwoWay}"
                                                             AutomationProperties.Name="{Binding Loc[PresetName]}" />
                                                    <ComboBox Grid.Column="1"
                                                              Width="132"
                                                              Classes="cfp-input"
                                                              ItemsSource="{Binding PresetModeOptions}"
                                                              SelectedItem="{Binding SelectedPresetModeOption, Mode=TwoWay}"
                                                              AutomationProperties.Name="{Binding Loc[PresetMode]}">
                                                        <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                </Grid>
                                                <WrapPanel Orientation="Horizontal">
                                                    <Button Classes="cfp-secondary" Command="{Binding RecaptureSelectedPresetCommand}" Margin="0,0,8,8" Content="{Binding Loc[RecapturePreset]}" />
                                                    <Button Classes="cfp-secondary" Click="ExportSelectedPreset" Margin="0,0,8,8" Content="{Binding Loc[ExportPreset]}" />
                                                    <Button Classes="cfp-secondary" Command="{Binding ShareSelectedPresetCommand}" Margin="0,0,8,8" Content="{Binding Loc[SharePreset]}" />
                                                    <Button Classes="cfp-secondary" Click="ConfirmDeletePreset" Margin="0,0,8,8" Content="{Binding Loc[DeletePreset]}" />
                                                </WrapPanel>
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                    <TextBox Classes="cfp-input"
                                                             Text="{Binding PresetCopyName, Mode=TwoWay}"
                                                             AutomationProperties.Name="{Binding Loc[CopyPreset]}" />
                                                    <Button Grid.Column="1" Classes="cfp-secondary" Command="{Binding CopySelectedPresetCommand}" Content="{Binding Loc[CopyPreset]}" />
                                                </Grid>
                                                <TextBlock Classes="cfp-meta" Text="{Binding Loc[PresetEntries]}" />
                                                <Border Classes="cfp-list-frame" MaxHeight="180">
                                                    <ItemsControl ItemsSource="{Binding SelectedPreset.Entries}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="models:ModPresetEntry">
                                                                <Grid ColumnDefinitions="*,Auto" Margin="10,7" ColumnSpacing="10">
                                                                    <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                                                    <TextBlock Grid.Column="1" Classes="cfp-caption" Text="{Binding Version}" />
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Border>
                                            </StackPanel>
                                        </Border>

                                        <Border Classes="cfp-card">
                                            <StackPanel Spacing="10">
                                                <WrapPanel Orientation="Horizontal">
                                                    <Button Classes="cfp-secondary" Click="ImportPresetFile" Margin="0,0,8,8" Content="{Binding Loc[ImportPreset]}" />
                                                </WrapPanel>
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                    <TextBox Classes="cfp-input"
                                                             Text="{Binding PresetShareCode, Mode=TwoWay}"
                                                             PlaceholderText="{Binding Loc[PresetShareCode]}"
                                                             AutomationProperties.Name="{Binding Loc[PresetShareCode]}" />
                                                    <Button Grid.Column="1" Classes="cfp-secondary" Command="{Binding ImportSharedPresetCommand}" Content="{Binding Loc[ImportSharedPreset]}" />
                                                </Grid>
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" IsVisible="{Binding HasLastPresetShare}">
                                                    <TextBlock Classes="cfp-caption"
                                                               Text="{Binding LastPresetShareUrl}"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center"
                                                               ToolTip.Tip="{Binding LastPresetShareUrl}" />
                                                    <Button Grid.Column="1" Classes="cfp-icon" Click="CopyPresetShareLink" ToolTip.Tip="{Binding Loc[PresetShareLink]}" AutomationProperties.Name="{Binding Loc[PresetShareLink]}" Content="{LucideIconContent Copy, 15}" />
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <StackPanel Spacing="16"
                                        Classes="cfp-tab-panel"
                                        IsVisible="{Binding CurrentManageTab, Converter={x:Static converters:ObjectConverters.Equal}, ConverterParameter=Snapshots}">
                                <StackPanel Spacing="16"
                                            IsVisible="{Binding IsEditingSave, Converter={x:Static converters:BoolConverters.Not}}">
                                    <TextBlock Classes="cfp-page-title" Text="{Binding Loc[Snapshots]}" />
                                    <WrapPanel Orientation="Horizontal">
                                        <TextBox Width="240"
                                                 Classes="cfp-input"
                                                 Text="{Binding SnapshotName, Mode=TwoWay}"
                                                 PlaceholderText="{Binding Loc[SnapshotName]}"
                                                 AutomationProperties.Name="{Binding Loc[SnapshotName]}"
                                                 Margin="0,0,8,8" />
                                        <Button Classes="cfp-accent"
                                                Command="{Binding CreateSnapshotCommand}"
                                                Margin="0,0,8,8">
                                            <Button.IsEnabled>
                                                <MultiBinding Converter="{x:Static converters:BoolConverters.And}">
                                                    <Binding Path="HasInstance" />
                                                    <Binding Path="SnapshotName" Converter="{x:Static converters:StringConverters.IsNotNullOrEmpty}" />
                                                    <Binding Path="IsBusy" Converter="{x:Static converters:BoolConverters.Not}" />
                                                    <Binding Path="IsGameRunning" Converter="{x:Static converters:BoolConverters.Not}" />
                                                </MultiBinding>
                                            </Button.IsEnabled>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <LucideIcon Kind="Camera" Size="16" />
                                                <TextBlock Text="{Binding Loc[CreateSnapshot]}" />
                                            </StackPanel>
                                        </Button>
                                    </WrapPanel>
                                    <Button Classes="cfp-market-item"
                                            Command="{Binding EditSaveCommand}"
                                            CommandParameter="current"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            IsVisible="{Binding HasInstance}"
                                            IsEnabled="{Binding IsGameRunning, Converter={x:Static converters:BoolConverters.Not}}">
                                        <Grid ColumnDefinitions="36,*,Auto" ColumnSpacing="10">
                                            <Border Width="32"
                                                    Height="32"
                                                    CornerRadius="6"
                                                    Background="{DynamicResource CfAccentSoftBrush}">
                                                <LucideIcon Kind="PenLine"
                                                            Size="16"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                                <TextBlock Classes="cfp-row-title" Text="{Binding SelectedInstance.Name}" />
                                                <TextBlock Classes="cfp-caption" Text="{Binding Loc[CurrentSave]}" />
                                            </StackPanel>
                                            <LucideIcon Grid.Column="2"
                                                        Kind="ChevronRight"
                                                        Size="16"
                                                        Foreground="{DynamicResource CfMutedTextBrush}"
                                                        VerticalAlignment="Center" />
                                        </Grid>
                                    </Button>
                                    <Border Classes="cfp-list-frame">
                                        <Grid>
                                            <ListBox Classes="cfp-list"
                                                     ItemsSource="{Binding Snapshots}"
                                                     SelectedItem="{Binding SelectedSnapshot, Mode=TwoWay}">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate x:DataType="models:NamedSnapshot">
                                                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                                                            <StackPanel Spacing="4">
                                                                <TextBlock Classes="cfp-row-title" Text="{Binding Name}" />
                                                                <TextBlock Classes="cfp-caption" Text="{Binding Id}" />
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="1"
                                                                       Classes="cfp-meta"
                                                                       Text="{Binding CreatedAt}"
                                                                       VerticalAlignment="Center" />
                                                            <Button Grid.Column="2"
                                                                    Classes="cfp-icon"
                                                                    Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).EditSaveCommand}"
                                                                    CommandParameter="{Binding Id}"
                                                                    VerticalAlignment="Center"
                                                                    IsEnabled="{Binding $parent[Window].((vm:MainViewModel)DataContext).IsGameRunning, Converter={x:Static converters:BoolConverters.Not}}"
                                                                    ToolTip.Tip="{Binding $parent[Window].((vm:MainViewModel)DataContext).Loc[EditSave]}"
                                                                    AutomationProperties.Name="{Binding $parent[Window].((vm:MainViewModel)DataContext).Loc[EditSave]}"
                                                                    Content="{LucideIconContent Pencil, 14}" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                            <TextBlock MinHeight="120"
                                                       Margin="24"
                                                       Classes="cfp-meta"
                                                       Text="{Binding Loc[NoSnapshotsAction]}"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       VerticalAlignment="Center"
                                                       IsVisible="{Binding Snapshots.Count, Converter={x:Static converters:ObjectConverters.Equal}, ConverterParameter={StaticResource Zero}}" />
                                        </Grid>
                                    </Border>
                                    <Button Classes="cfp-secondary"
                                            Click="ConfirmRestoreSnapshot"
                                            HorizontalAlignment="Right">
                                        <Button.IsEnabled>
                                            <MultiBinding Converter="{x:Static converters:BoolConverters.And}">
                                                <Binding Path="SelectedSnapshot" Converter="{x:Static converters:ObjectConverters.IsNotNull}" />
                                                <Binding Path="IsBusy" Converter="{x:Static converters:BoolConverters.Not}" />
                                                <Binding Path="IsGameRunning" Converter="{x:Static converters:BoolConverters.Not}" />
                                            </MultiBinding>
                                        </Button.IsEnabled>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <LucideIcon Kind="ArchiveRestore" Size="16" />
                                            <TextBlock Text="{Binding Loc[Restore]}" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>

                                <StackPanel Spacing="12"
                                            IsVisible="{Binding $parent[Window].((vm:MainViewModel)DataContext).IsEditingSave}"
                                            DataContext="{Binding SaveEditor}">
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                        <Button Classes="cfp-secondary"
                                                Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).ExitSaveEditorCommand}">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <LucideIcon Kind="ArrowLeft" Size="16" />
                                                <TextBlock Text="{Binding $parent[Window].((vm:MainViewModel)DataContext).Loc[Back]}" />
                                            </StackPanel>
                                        </Button>
                                        <TextBlock Grid.Column="1"
                                                   Classes="cfp-page-title"
                                                   Text="{Binding SourceLabel}"
                                                   VerticalAlignment="Center" />
                                        <ComboBox Grid.Column="2"
                                                  Classes="cfp-input"
                                                  MinWidth="180"
                                                  ItemsSource="{Binding Slots}"
                                                  SelectedItem="{Binding SelectedSlot, Mode=TwoWay}"
                                                  SelectionChanged="OnSaveSlotSelectionChanged"
                                                  AutomationProperties.Name="{Binding $parent[Window].((vm:MainViewModel)DataContext).Loc[SaveSlot]}" />
                                    </Grid>
                                    <u:LoadingContainer Name="SaveEditorLoadingHost"
                                                        MinHeight="480"
                                                        IsLoading="{Binding IsLoaded, Converter={x:Static converters:BoolConverters.Not}}"
                                                        HorizontalContentAlignment="Stretch"
                                                        VerticalContentAlignment="Stretch">
                                        <u:LoadingContainer.Indicator>
                                            <Border Name="SaveEditorKnightLoadingViewport"
                                                    Width="45"
                                                    Height="72"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    ClipToBounds="True">
                                                <Image Name="SaveEditorKnightWalkImage"
                                                       Width="180"
                                                       Height="72"
                                                       HorizontalAlignment="Left"
                                                       VerticalAlignment="Center"
                                                       Source="/Assets/knight-walk.png" />
                                            </Border>
                                        </u:LoadingContainer.Indicator>
                                        <Grid IsVisible="{Binding IsLoaded}">
                                            <Border Classes="cfp-list-frame" MaxHeight="480">
                                                <ListBox Classes="cfp-list cfp-save-entry-list"
                                                         ItemsSource="{Binding Entries}">
                                                    <ListBox.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <VirtualizingStackPanel />
                                                        </ItemsPanelTemplate>
                                                    </ListBox.ItemsPanel>
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:SaveEntryViewModel">
                                                            <Grid ColumnDefinitions="2*,3*,80"
                                                                  ColumnSpacing="8"
                                                                  Margin="0,0,0,4">
                                                                <TextBlock Classes="cfp-caption"
                                                                           Text="{Binding Path}"
                                                                           VerticalAlignment="Center"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           ToolTip.Tip="{Binding Path}" />
                                                                <TextBox Grid.Column="1"
                                                                         Classes="cfp-input"
                                                                         Text="{Binding Value, Mode=TwoWay}"
                                                                         AutomationProperties.Name="{Binding Path}" />
                                                                <TextBlock Grid.Column="2"
                                                                           Classes="cfp-meta"
                                                                           Text="{Binding Kind}"
                                                                           VerticalAlignment="Center" />
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </Border>
                                            <TextBlock Margin="24"
                                                       Classes="cfp-meta"
                                                       Text="{Binding $parent[Window].((vm:MainViewModel)DataContext).Loc[NoSaveSlots]}"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       IsVisible="{Binding Slots.Count, Converter={x:Static converters:ObjectConverters.Equal}, ConverterParameter={StaticResource Zero}}" />
                                        </Grid>
                                    </u:LoadingContainer>
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8"
                                                HorizontalAlignment="Right">
                                        <Button Classes="cfp-secondary" Command="{Binding ResetCommand}">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <LucideIcon Kind="RotateCcw" Size="16" />
                                                <TextBlock Text="{Binding $parent[Window].((vm:MainViewModel)DataContext).Loc[ResetConfig]}" />
                                            </StackPanel>
                                        </Button>
                                        <Button Classes="cfp-primary"
                                                Command="{Binding SaveCommand}"
                                                IsEnabled="{Binding CanSave}">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <LucideIcon Kind="Save" Size="16" />
                                                <TextBlock Text="{Binding $parent[Window].((vm:MainViewModel)DataContext).Loc[Save]}" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Spacing="16"
                                        Classes="cfp-tab-panel"
                                        IsVisible="{Binding CurrentManageTab, Converter={x:Static converters:ObjectConverters.Equal}, ConverterParameter=Logs}">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <TextBlock Grid.Column="0" Classes="cfp-page-title" Text="{Binding Loc[Logs]}" />
                                    <Button Grid.Column="1"
                                            Classes="cfp-secondary"
                                            Command="{Binding RefreshLogsCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <LucideIcon Kind="RefreshCw" Size="16" />
                                            <TextBlock Text="{Binding Loc[RefreshLogs]}" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                                <Grid ColumnDefinitions="240,16,*" MinHeight="360">
                                    <Border Grid.Column="0" Classes="cfp-list-frame">
                                        <Grid>
                                            <ListBox Classes="cfp-list"
                                                     ItemsSource="{Binding InstanceLogs}"
                                                     SelectedItem="{Binding SelectedLogFile, Mode=TwoWay}">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate x:CompileBindings="False">
                                                        <StackPanel Spacing="3">
                                                            <TextBlock Classes="cfp-row-title" Text="{Binding Name}" />
                                                            <TextBlock Classes="cfp-caption" Text="{Binding SizeBytes}" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                            <TextBlock Margin="20"
                                                       Classes="cfp-meta"
                                                       Text="{Binding Loc[NoLogs]}"
                                                       TextWrapping="Wrap"
                                                       TextAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       IsVisible="{Binding InstanceLogs.Count, Converter={x:Static converters:ObjectConverters.Equal}, ConverterParameter={StaticResource Zero}}" />
                                        </Grid>
                                    </Border>
                                    <Grid Grid.Column="2" RowDefinitions="Auto,*" RowSpacing="8">
                                        <TextBlock Grid.Row="0"
                                                   Classes="cfp-caption"
                                                   Text="{Binding SelectedLogFile.Path}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip.Tip="{Binding SelectedLogFile.Path}" />
                                        <TextBox Grid.Row="1"
                                                 Classes="cfp-input"
                                                 Text="{Binding LogContent}"
                                                 IsReadOnly="True"
                                                  AcceptsReturn="True"
                                                  TextWrapping="NoWrap"
                                                  FontFamily="Consolas"
                                                  AutomationProperties.Name="{Binding Loc[Logs]}"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto" />
                                    </Grid>
                                </Grid>
                            </StackPanel>

                            <StackPanel Name="GameConfigPanel"
                                        Spacing="16"
                                        Classes="cfp-tab-panel"
                                        IsVisible="{Binding CurrentManageTab, Converter={x:Static converters:ObjectConverters.Equal}, ConverterParameter=Config}">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="cfp-page-title" Text="{Binding Loc[Config]}" />
                                    <TextBlock Classes="cfp-meta"
                                               Text="{Binding Loc[ConfigHint]}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <Border Classes="cfp-error" IsVisible="{Binding IsGameRunning}">
                                    <TextBlock Text="{Binding Loc[ConfigLocked]}" TextWrapping="Wrap" />
                                </Border>
                                <Border Classes="cfp-card"
                                        IsVisible="{Binding GameConfig, Converter={x:Static converters:ObjectConverters.IsNotNull}}">
                                    <StackPanel Spacing="16"
                                                IsEnabled="{Binding IsGameRunning, Converter={x:Static converters:BoolConverters.Not}}">
                                        <StackPanel Spacing="10">
                                            <TextBlock Classes="cfp-section-title" Text="{Binding Loc[Accessibility]}" />
                                            <Grid ColumnDefinitions="220,*,64"
                                                  ColumnSpacing="12"
                                                  IsVisible="{Binding SupportsAccessibility}">
                                                <TextBlock Text="{Binding Loc[ReducedCameraShake]}"
                                                           VerticalAlignment="Center" />
                                                <Slider Grid.Column="1"
                                                        Minimum="0"
                                                        Maximum="1"
                                                        TickFrequency="0.05"
                                                        IsSnapToTickEnabled="True"
                                                        Value="{Binding GameConfig.ReducedCameraShake, Mode=TwoWay}"
                                                        VerticalAlignment="Center"
                                                        AutomationProperties.Name="{Binding Loc[ReducedCameraShake]}" />
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding GameConfig.ReducedCameraShake, StringFormat={}{0:0.00}}"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Right" />
                                            </Grid>
                                            <Grid ColumnDefinitions="220,*,64" ColumnSpacing="12">
                                                <TextBlock Text="{Binding Loc[ReducedControllerRumble]}"
                                                           VerticalAlignment="Center" />
                                                <Slider Grid.Column="1"
                                                        Minimum="0"
                                                        Maximum="1"
                                                        TickFrequency="0.05"
                                                        IsSnapToTickEnabled="True"
                                                        Value="{Binding GameConfig.ReducedControllerRumble, Mode=TwoWay}"
                                                        VerticalAlignment="Center"
                                                        AutomationProperties.Name="{Binding Loc[ReducedControllerRumble]}" />
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding GameConfig.ReducedControllerRumble, StringFormat={}{0:0.00}}"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Right" />
                                            </Grid>
                                        </StackPanel>
                                        <StackPanel Spacing="8">
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                <StackPanel Spacing="2">
                                                    <TextBlock Classes="cfp-section-title" Text="{Binding Loc[AdvancedConfig]}" />
                                                    <TextBlock Classes="cfp-meta"
                                                               Text="{Binding Loc[AdvancedConfigHint]}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        Classes="cfp-secondary"
                                                        Command="{Binding GameConfig.AddEntryCommand}"
                                                        VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <LucideIcon Kind="Plus" Size="16" />
                                                        <TextBlock Text="{Binding Loc[AddEntry]}" />
                                                    </StackPanel>
                                                </Button>
                                            </Grid>
                                            <Grid ColumnDefinitions="150,190,*,Auto" ColumnSpacing="8">
                                                <TextBlock Classes="cfp-caption" Text="{Binding Loc[ConfigSection]}" />
                                                <TextBlock Grid.Column="1" Classes="cfp-caption" Text="{Binding Loc[ConfigKey]}" />
                                                <TextBlock Grid.Column="2" Classes="cfp-caption" Text="{Binding Loc[ConfigValue]}" />
                                            </Grid>
                                            <ItemsControl ItemsSource="{Binding GameConfig.Entries}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:ConfigEntryViewModel">
                                                        <Grid ColumnDefinitions="150,190,*,Auto"
                                                              ColumnSpacing="8"
                                                              Margin="0,0,0,6">
                                                            <TextBox Classes="cfp-input"
                                                                     Text="{Binding Section, Mode=TwoWay}"
                                                                     AutomationProperties.Name="{Binding #Root.DataContext.Loc[ConfigSection]}" />
                                                            <TextBox Grid.Column="1"
                                                                     Classes="cfp-input"
                                                                     Text="{Binding Key, Mode=TwoWay}"
                                                                     AutomationProperties.Name="{Binding #Root.DataContext.Loc[ConfigKey]}" />
                                                            <TextBox Grid.Column="2"
                                                                     Classes="cfp-input"
                                                                     Text="{Binding Value, Mode=TwoWay}"
                                                                     AutomationProperties.Name="{Binding #Root.DataContext.Loc[ConfigValue]}" />
                                                            <Button Grid.Column="3"
                                                                    Classes="cfp-icon"
                                                                    Command="{Binding #Root.DataContext.GameConfig.RemoveEntryCommand}"
                                                                    CommandParameter="{Binding}"
                                                                    ToolTip.Tip="{Binding #Root.DataContext.Loc[RemoveEntry]}"
                                                                    AutomationProperties.Name="{Binding #Root.DataContext.Loc[RemoveEntry]}"
                                                                    Content="{LucideIconContent Trash2, 16}" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                        <WrapPanel Orientation="Horizontal">
                                            <Button Name="ConfigSaveButton"
                                                    Classes="cfp-accent"
                                                    Command="{Binding GameConfig.SaveCommand}"
                                                    IsEnabled="{Binding GameConfig.IsDirty}"
                                                    Margin="0,0,8,8">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <LucideIcon Kind="Save" Size="16" />
                                                    <TextBlock Text="{Binding Loc[SaveConfig]}" />
                                                </StackPanel>
                                            </Button>
                                            <Button Name="ConfigResetButton"
                                                    Classes="cfp-secondary"
                                                    Command="{Binding GameConfig.ResetCommand}"
                                                    Margin="0,0,8,8">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <LucideIcon Kind="RotateCcw" Size="16" />
                                                    <TextBlock Text="{Binding Loc[ResetConfig]}" />
                                                </StackPanel>
                                            </Button>
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                    <Grid Grid.Column="1"
                          Classes="cfp-mods-workspace cfp-tab-panel"
                          Margin="24"
                          MaxWidth="1920"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          RowDefinitions="Auto,Auto,Auto,*,Auto"
                          RowSpacing="12"
                          IsVisible="{Binding CurrentManageTab, Converter={x:Static converters:ObjectConverters.Equal}, ConverterParameter=Mods}">
                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <StackPanel Spacing="3">
                                <TextBlock Classes="cfp-page-title" Text="{Binding Loc[InstalledMods]}" />
                                <TextBlock Classes="cfp-meta" Text="{Binding SelectedModCount}" />
                            </StackPanel>
                            <WrapPanel Grid.Column="1" Classes="cfp-mod-quick-actions" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Classes="cfp-icon cfp-quick-action" Click="OpenInstalledModRoot" ToolTip.Tip="{Binding Loc[OpenFolder]}" AutomationProperties.Name="{Binding Loc[OpenFolder]}" Content="{LucideIconContent FolderOpen, 16}" />
                                <Button Classes="cfp-icon cfp-quick-action" Click="ImportLocalModPackage" ToolTip.Tip="{Binding Loc[ImportLocalMod]}" AutomationProperties.Name="{Binding Loc[ImportLocalMod]}" Content="{LucideIconContent PackagePlus, 16}" />
                                <Button Classes="cfp-icon cfp-quick-action" Command="{Binding OpenModMarketForSelectedInstanceCommand}" ToolTip.Tip="{Binding Loc[ModMarket]}" AutomationProperties.Name="{Binding Loc[ModMarket]}" Content="{LucideIconContent Store, 16}" />
                                <Button Classes="cfp-icon cfp-quick-action" Command="{Binding SelectAllInstalledModsCommand}" ToolTip.Tip="{Binding Loc[SelectAll]}" AutomationProperties.Name="{Binding Loc[SelectAll]}" Content="{LucideIconContent ListChecks, 16}" />
                            </WrapPanel>
                        </Grid>
                        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <TextBox Classes="cfp-input" Text="{Binding ModSearchText, Mode=TwoWay}" PlaceholderText="{Binding Loc[FilterMods]}" AutomationProperties.Name="{Binding Loc[FilterMods]}" />
                            <ComboBox Grid.Column="1" Width="160" Classes="cfp-input" ItemsSource="{Binding ModStatusOptions}" SelectedItem="{Binding SelectedModStatusOption, Mode=TwoWay}" AutomationProperties.Name="{Binding Loc[FilterAll]}">
                                <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>
                        <StackPanel Grid.Row="2" Spacing="6">
                            <Border Classes="cfp-error" IsVisible="{Binding HasModDependencyProblems}">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <TextBlock Text="{Binding Loc[DependencyProblem]}" VerticalAlignment="Center" />
                                    <Button Grid.Column="1" Classes="cfp-secondary" Click="ConfirmRepairDependencies" Content="{Binding Loc[RepairDependencies]}" />
                                </Grid>
                            </Border>
                            <Border Classes="cfp-card" Padding="10,7" IsVisible="{Binding HasUnusedDependencySuggestions}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <LucideIcon Kind="Info" Size="15" />
                                    <TextBlock Classes="cfp-meta" Text="{Binding UnusedDependencySummary}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <Border Grid.Row="3" Classes="cfp-list-frame">
                            <ListBox x:Name="InstalledModsList" Classes="cfp-list cfp-installed-mod-list" ItemsSource="{Binding VisibleInstalledMods}" SelectedItem="{Binding SelectedInstalledMod, Mode=TwoWay}" KeyDown="OnInstalledModsKeyDown">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:InstalledModItemViewModel">
                                        <Grid Classes="cfp-installed-mod-row" Classes.selected="{Binding IsSelected}" Classes.disabled="{Binding IsEnabled, Converter={x:Static converters:BoolConverters.Not}}" ColumnDefinitions="3,*,Auto" ColumnSpacing="8" PointerPressed="OnInstalledModPointerPressed">
                                            <Border Classes="cfp-installed-mod-accent" Width="3" CornerRadius="2" Background="{DynamicResource CfAccentBrush}" />
                                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                                <TextBlock Classes="cfp-installed-mod-name" Text="{Binding PrimaryName}" Classes.disabled="{Binding IsEnabled, Converter={x:Static converters:BoolConverters.Not}}" TextTrimming="CharacterEllipsis" />
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Classes="cfp-meta" Text="{Binding SecondaryName}" IsVisible="{Binding HasSecondaryName}" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Classes="cfp-meta" Text="{Binding Version}" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Classes="cfp-meta" Text="{Binding OwnershipDisplayName}" />
                                                    <TextBlock Classes="cfp-meta" Text="{Binding HealthDisplayName}" />
                                                    <TextBlock Classes="cfp-meta" Text="{Binding #Root.DataContext.Loc[Pinned]}" IsVisible="{Binding IsPinned}" />
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Classes="cfp-installed-mod-actions" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                                                <Button Classes="cfp-icon cfp-mod-action" Click="OpenInstalledModInfo" IsVisible="{Binding HasCatalogManifest}" ToolTip.Tip="{Binding #Root.DataContext.Loc[Information]}" AutomationProperties.Name="{Binding #Root.DataContext.Loc[Information]}" Content="{LucideIconContent Info, 15}" />
                                                <Button Classes="cfp-icon cfp-mod-action" Click="OpenInstalledModFolder" ToolTip.Tip="{Binding #Root.DataContext.Loc[OpenFolder]}" AutomationProperties.Name="{Binding #Root.DataContext.Loc[OpenFolder]}" Content="{LucideIconContent FolderOpen, 15}" />
                                                <Button Classes="cfp-icon cfp-mod-action" Click="ShowInstalledModHealth" IsVisible="{Binding HasHealthIssue}" ToolTip.Tip="{Binding HealthDisplayName}" AutomationProperties.Name="{Binding HealthDisplayName}" Content="{LucideIconContent ShieldAlert, 15}" />
                                                <Button Classes="cfp-icon cfp-mod-action" Click="TakeOverHoveredInstalledMod" IsVisible="{Binding CanTakeOver}" ToolTip.Tip="{Binding #Root.DataContext.Loc[TakeOverMod]}" AutomationProperties.Name="{Binding #Root.DataContext.Loc[TakeOverMod]}" Content="{LucideIconContent Import, 15}" />
                                                <Button Classes="cfp-icon cfp-mod-action" Click="RepairHoveredInstalledMod" IsVisible="{Binding CanRepair}" ToolTip.Tip="{Binding #Root.DataContext.Loc[RepairMod]}" AutomationProperties.Name="{Binding #Root.DataContext.Loc[RepairMod]}" Content="{LucideIconContent Wrench, 15}" />
                                                <Button Classes="cfp-icon cfp-mod-action" Click="AcceptHoveredLocalModFiles" IsVisible="{Binding CanAcceptCurrent}" ToolTip.Tip="{Binding #Root.DataContext.Loc[AcceptCurrentFiles]}" AutomationProperties.Name="{Binding #Root.DataContext.Loc[AcceptCurrentFiles]}" Content="{LucideIconContent FileCheck, 15}" />
                                                <Button Classes="cfp-icon cfp-mod-action" Click="ReimportHoveredLocalMod" IsVisible="{Binding CanReimport}" ToolTip.Tip="{Binding #Root.DataContext.Loc[ReimportLocalMod]}" AutomationProperties.Name="{Binding #Root.DataContext.Loc[ReimportLocalMod]}" Content="{LucideIconContent PackageOpen, 15}" />
                                                <Button Classes="cfp-icon cfp-mod-action" Click="ToggleHoveredModPinned" IsVisible="{Binding CanPin}" ToolTip.Tip="{Binding #Root.DataContext.Loc[PinMod]}" AutomationProperties.Name="{Binding #Root.DataContext.Loc[PinMod]}" Content="{LucideIconContent Pin, 15}" />
                                                <Button Classes="cfp-icon cfp-mod-action" Click="ToggleHoveredInstalledMod" IsVisible="{Binding CanToggle}" ToolTip.Tip="{Binding #Root.DataContext.Loc[EnableDisable]}" AutomationProperties.Name="{Binding #Root.DataContext.Loc[EnableDisable]}" Content="{LucideIconContent Power, 15}" />
                                                <Button Classes="cfp-icon cfp-mod-action danger" Click="ConfirmHoveredModUninstall" IsVisible="{Binding CanUninstall}" ToolTip.Tip="{Binding #Root.DataContext.Loc[Uninstall]}" AutomationProperties.Name="{Binding #Root.DataContext.Loc[Uninstall]}" Content="{LucideIconContent Trash2, 15}" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                        <Border Grid.Row="4" Classes="cfp-mod-bulk-bar" IsVisible="{Binding HasSelectedMods}">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                <TextBlock Classes="cfp-row-title" Text="{Binding SelectedModCount}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Classes="cfp-meta" Text="{Binding Loc[SelectedMods]}" VerticalAlignment="Center" />
                                <WrapPanel Grid.Column="2" Orientation="Horizontal">
                                    <Button Classes="cfp-icon" Command="{Binding EnableSelectedModsCommand}" ToolTip.Tip="{Binding Loc[Enable]}" AutomationProperties.Name="{Binding Loc[Enable]}" Content="{LucideIconContent CirclePlay, 15}" />
                                    <Button Classes="cfp-icon" Command="{Binding DisableSelectedModsCommand}" ToolTip.Tip="{Binding Loc[Disable]}" AutomationProperties.Name="{Binding Loc[Disable]}" Content="{LucideIconContent CirclePause, 15}" />
                                    <Button Classes="cfp-icon" Command="{Binding UpdateSelectedModsCommand}" ToolTip.Tip="{Binding Loc[Update]}" AutomationProperties.Name="{Binding Loc[Update]}" Content="{LucideIconContent RefreshCw, 15}" />
                                    <Button Classes="cfp-icon danger" Click="ConfirmBulkUninstallMods" ToolTip.Tip="{Binding Loc[Uninstall]}" AutomationProperties.Name="{Binding Loc[Uninstall]}" Content="{LucideIconContent Trash2, 15}" />
                                    <Button Classes="cfp-icon" Command="{Binding ClearInstalledModSelectionCommand}" ToolTip.Tip="{Binding Loc[ClearSelection]}" AutomationProperties.Name="{Binding Loc[ClearSelection]}" Content="{LucideIconContent X, 15}" />
                                </WrapPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>

            <!-- Speedrun -->
            <Grid Classes="cfp-page" IsVisible="{Binding IsSpeedrunPage}">
                <ScrollViewer
                              HorizontalContentAlignment="Stretch"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Classes="cfp-workspace"
                                Margin="24"
                                Spacing="16"
                                MaxWidth="1920"
                                HorizontalAlignment="Stretch">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="cfp-page-title" Text="{Binding Loc[SpeedrunTitle]}" />
                            <TextBlock Classes="cfp-meta" Text="{Binding Loc[SpeedrunHint]}" TextWrapping="Wrap" />
                        </StackPanel>
                        <Grid ColumnDefinitions="*,16,*">
                            <Border Grid.Column="0" Classes="cfp-list-frame">
                                <Grid>
                                    <ListBox Classes="cfp-list"
                                             ItemsSource="{Binding SpeedrunTemplates}"
                                             SelectedItem="{Binding SelectedSpeedrunTemplate, Mode=TwoWay}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="models:SpeedrunTemplate">
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                    <StackPanel Spacing="4">
                                                        <TextBlock Classes="cfp-row-title" Text="{Binding Name}" TextWrapping="Wrap" />
                                                        <TextBlock Classes="cfp-caption" Text="{Binding BuildId}" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1"
                                                               Classes="cfp-meta"
                                                               MaxWidth="160"
                                                               Text="{Binding RulesRevision}"
                                                               TextWrapping="Wrap"
                                                               VerticalAlignment="Center" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <StackPanel MinHeight="160"
                                                Margin="24"
                                                Spacing="12"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                IsVisible="{Binding SpeedrunTemplates.Count, Converter={x:Static converters:ObjectConverters.Equal}, ConverterParameter={StaticResource Zero}}">
                                        <TextBlock Classes="cfp-meta"
                                                   Text="{Binding Loc[NoSpeedrunTemplatesAction]}"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap" />
                                        <Button Classes="cfp-secondary"
                                                Command="{Binding SelectPageCommand}"
                                                CommandParameter="Settings">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <LucideIcon Kind="Settings" Size="16" />
                                                <TextBlock Text="{Binding Loc[OpenSettings]}" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Grid.Column="2" Classes="cfp-card">
                                <StackPanel Spacing="12">
                                    <TextBlock Classes="cfp-section-title" Text="{Binding Loc[CreateEnvironment]}" />
                                    <TextBlock Classes="cfp-meta"
                                               Text="{Binding SelectedSpeedrunTemplate.Name}"
                                               TextWrapping="Wrap" />
                                    <TextBox Classes="cfp-input"
                                             Text="{Binding SpeedrunEnvironmentName, Mode=TwoWay}"
                                             PlaceholderText="{Binding Loc[EnvironmentName]}"
                                             AutomationProperties.Name="{Binding Loc[EnvironmentName]}" />
                                    <StackPanel Spacing="6"
                                                IsVisible="{Binding SelectedSpeedrunTemplate.RequiresLoadNormaliserSelection}">
                                        <TextBlock Classes="cfp-caption" Text="{Binding Loc[LoadNormaliserSeconds]}" />
                                        <ComboBox Classes="cfp-input"
                                                  ItemsSource="{Binding SelectedSpeedrunTemplate.AllowedLoadNormaliserSeconds}"
                                                  SelectedItem="{Binding SelectedLoadNormaliserSeconds, Mode=TwoWay}"
                                                  AutomationProperties.Name="{Binding Loc[LoadNormaliserSeconds]}" />
                                    </StackPanel>
                                    <Button Classes="cfp-primary"
                                            Command="{Binding CreateSpeedrunEnvironmentCommand}">
                                        <Button.IsEnabled>
                                            <MultiBinding Converter="{x:Static converters:BoolConverters.And}">
                                                <Binding Path="SelectedSpeedrunTemplate" Converter="{x:Static converters:ObjectConverters.IsNotNull}" />
                                                <Binding Path="SpeedrunEnvironmentName" Converter="{x:Static converters:StringConverters.IsNotNullOrEmpty}" />
                                                <Binding Path="IsBusy" Converter="{x:Static converters:BoolConverters.Not}" />
                                                <Binding Path="IsGameRunning" Converter="{x:Static converters:BoolConverters.Not}" />
                                            </MultiBinding>
                                        </Button.IsEnabled>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <LucideIcon Kind="PackagePlus" Size="16" />
                                            <TextBlock Text="{Binding Loc[CreateEnvironment]}" />
                                        </StackPanel>
                                    </Button>
                                    <TextBlock Classes="cfp-meta" Text="{Binding SpeedrunStatus}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Downloads -->
            <Grid Classes="cfp-page" IsVisible="{Binding IsDownloadsPage}">
                <Grid ColumnDefinitions="176,*" x:CompileBindings="False">
                    <Border Grid.Column="0" Classes="cfp-rail cfp-download-rail" Padding="8,16">
                        <StackPanel Classes="cfp-manage-nav" Spacing="4" IsEnabled="{Binding CanNavigate}">
                            <Button Classes="cfp-local-nav"
                                    Classes.active="{Binding IsGameVersionsDownloadSection}"
                                    Command="{Binding SelectDownloadSectionCommand}"
                                    CommandParameter="GameVersions"
                                    AutomationProperties.Name="{Binding Loc[GameVersions]}">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                    <LucideIcon Kind="HardDriveDownload" Size="16" />
                                    <TextBlock Grid.Column="1" Text="{Binding Loc[GameVersions]}" />
                                </Grid>
                            </Button>
                            <Button Classes="cfp-local-nav"
                                    Classes.active="{Binding IsModMarketDownloadSection}"
                                    Command="{Binding SelectDownloadSectionCommand}"
                                    CommandParameter="ModMarket"
                                    AutomationProperties.Name="{Binding Loc[ModMarket]}">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                    <LucideIcon Kind="Store" Size="16" />
                                    <TextBlock Grid.Column="1" Text="{Binding Loc[ModMarket]}" />
                                </Grid>
                            </Button>
                            <Button Classes="cfp-local-nav"
                                    Classes.active="{Binding IsDownloadQueueSection}"
                                    Command="{Binding SelectDownloadSectionCommand}"
                                    CommandParameter="DownloadQueue"
                                    AutomationProperties.Name="{Binding Loc[DownloadQueue]}">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                    <LucideIcon Kind="ListTodo" Size="16" />
                                    <TextBlock Grid.Column="1" Text="{Binding Loc[DownloadQueue]}" />
                                </Grid>
                            </Button>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Column="1"
                                  IsVisible="{Binding IsGameVersionsDownloadSection}"
                                  HorizontalContentAlignment="Stretch"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Classes="cfp-workspace"
                                    Margin="24"
                                    Spacing="16"
                                    MaxWidth="1920"
                                    HorizontalAlignment="Stretch">
                            <StackPanel Spacing="4">
                                <TextBlock Classes="cfp-page-title" Text="{Binding Loc[GameVersions]}" />
                                <TextBlock Classes="cfp-meta" Text="{Binding Loc[DownloadsHint]}" TextWrapping="Wrap" />
                            </StackPanel>
                            <Grid ColumnDefinitions="280,16,*">
                                <Border Grid.Column="0" Classes="cfp-card" VerticalAlignment="Top">
                                    <StackPanel Spacing="12">
                                        <TextBlock Classes="cfp-section-title" Text="{Binding Loc[SteamAccount]}" />
                                        <TextBlock Classes="cfp-meta" Text="{Binding SteamStatus}" TextWrapping="Wrap" />
                                        <Image Width="180"
                                               Height="180"
                                               Source="{Binding QrCodeImage}"
                                               HorizontalAlignment="Left"
                                               AutomationProperties.Name="{Binding Loc[SignInQr]}"
                                               IsVisible="{Binding QrCodeImage, Converter={x:Static converters:ObjectConverters.IsNotNull}}" />
                                        <Button Classes="cfp-accent"
                                                Command="{Binding SignInWithQrCommand}"
                                                HorizontalAlignment="Left"
                                                IsVisible="{Binding IsSteamLoggedIn, Converter={x:Static converters:BoolConverters.Not}}">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <LucideIcon Kind="LogIn" Size="16" />
                                                <TextBlock Text="{Binding Loc[SignInQr]}" />
                                            </StackPanel>
                                        </Button>
                                        <Button Classes="cfp-secondary"
                                                Command="{Binding SignOutSteamCommand}"
                                                HorizontalAlignment="Left"
                                                IsVisible="{Binding IsSteamLoggedIn}">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <LucideIcon Kind="LogOut" Size="16" />
                                                <TextBlock Text="{Binding Loc[SignOut]}" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Classes="cfp-card" VerticalAlignment="Top">
                                    <StackPanel Spacing="12">
                                        <TextBlock Classes="cfp-section-title" Text="{Binding Loc[GameVersions]}" />
                                        <ComboBox Classes="cfp-input"
                                                  ItemsSource="{Binding DownloadBuilds}"
                                                  SelectedItem="{Binding SelectedDownloadBuild, Mode=TwoWay}"
                                                  AutomationProperties.Name="{Binding Loc[GameVersions]}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate x:DataType="vm:DownloadBuildOption">
                                                    <TextBlock Text="{Binding DisplayName}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <StackPanel Spacing="8"
                                                    IsVisible="{Binding DownloadBuilds.Count, Converter={x:Static converters:ObjectConverters.Equal}, ConverterParameter={StaticResource Zero}}">
                                            <TextBlock Classes="cfp-meta"
                                                       Text="{Binding Loc[NoDownloadBuildsAction]}"
                                                       TextWrapping="Wrap" />
                                            <Button Classes="cfp-secondary"
                                                    Command="{Binding SelectPageCommand}"
                                                    CommandParameter="Settings"
                                                    HorizontalAlignment="Left">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <LucideIcon Kind="Settings" Size="16" />
                                                    <TextBlock Text="{Binding Loc[OpenSettings]}" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                        <ProgressBar x:Name="SteamDownloadProgress"
                                                     Minimum="0"
                                                     Maximum="1"
                                                     Value="{Binding DownloadProgress}"
                                                     IsVisible="{Binding IsDownloading}" />
                                        <TextBlock Classes="cfp-meta" Text="{Binding DownloadStatus}" TextWrapping="Wrap" />
                                        <Button Classes="cfp-primary"
                                                Command="{Binding DownloadBuildCommand}"
                                                IsVisible="{Binding IsDownloading, Converter={x:Static converters:BoolConverters.Not}}">
                                            <Button.IsEnabled>
                                                <MultiBinding Converter="{x:Static converters:BoolConverters.And}">
                                                    <Binding Path="IsSteamLoggedIn" />
                                                    <Binding Path="SelectedDownloadBuild" Converter="{x:Static converters:ObjectConverters.IsNotNull}" />
                                                    <Binding Path="IsBusy" Converter="{x:Static converters:BoolConverters.Not}" />
                                                    <Binding Path="IsGameRunning" Converter="{x:Static converters:BoolConverters.Not}" />
                                                </MultiBinding>
                                            </Button.IsEnabled>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <LucideIcon Kind="Download" Size="16" />
                                                <TextBlock Text="{Binding Loc[NavDownloads]}" />
                                            </StackPanel>
                                        </Button>
                                        <Button Classes="cfp-secondary"
                                                Command="{Binding CancelDownloadCommand}"
                                                IsVisible="{Binding IsDownloading}">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <LucideIcon Kind="X" Size="16" />
                                                <TextBlock Text="{Binding Loc[Cancel]}" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <Grid Grid.Column="1" IsVisible="{Binding IsModMarketDownloadSection}">
                        <Grid IsVisible="{Binding IsMarketList}" RowDefinitions="Auto,*">
                            <StackPanel Grid.Row="0" Margin="24,16,24,8" Spacing="8">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="cfp-page-title" Text="{Binding Loc[MarketTitle]}" />
                                    <TextBlock Classes="cfp-meta" Text="{Binding Loc[MarketHint]}" TextWrapping="Wrap" />
                                </StackPanel>
                                <Border Classes="cfp-card cfp-market-source">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                                        <TextBlock Classes="cfp-row-title"
                                                   Text="{Binding OfficialModCatalogStatus}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1"
                                                   Classes="cfp-meta"
                                                   Text="{Binding OfficialModCatalogSummary}"
                                                   TextWrapping="Wrap"
                                                   TextAlignment="Right"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Foreground="{DynamicResource CfErrorBrush}"
                                                   Text="{Binding OfficialModCatalogError}"
                                                   TextWrapping="Wrap"
                                                   Grid.ColumnSpan="2"
                                                   IsVisible="{Binding OfficialModCatalogError, Converter={x:Static converters:StringConverters.IsNotNullOrEmpty}}" />
                                    </Grid>
                                </Border>
                                <TextBox Classes="cfp-input"
                                         Text="{Binding MarketSearchText, Mode=TwoWay}"
                                         PlaceholderText="{Binding Loc[MarketSearch]}"
                                         AutomationProperties.Name="{Binding Loc[MarketSearch]}" />
                                <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="8">
                                    <ComboBox Grid.Column="0" Classes="cfp-input" HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding MarketBuildOptions}"
                                              SelectedItem="{Binding SelectedMarketBuildOption, Mode=TwoWay}"
                                              AutomationProperties.Name="{Binding Loc[MarketBuild]}">
                                        <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <ComboBox Grid.Column="1" Classes="cfp-input" HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding MarketLoaderOptions}"
                                              SelectedItem="{Binding SelectedMarketLoaderOption, Mode=TwoWay}"
                                              AutomationProperties.Name="{Binding Loc[MarketLoader]}">
                                        <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <ComboBox Grid.Column="2" Classes="cfp-input" HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding MarketSourceOptions}"
                                              SelectedItem="{Binding SelectedMarketSourceOption, Mode=TwoWay}"
                                              AutomationProperties.Name="{Binding Loc[MarketSource]}">
                                        <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <ComboBox Grid.Column="3" Classes="cfp-input" HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding MarketTagOptions}"
                                              SelectedItem="{Binding SelectedMarketTagOption, Mode=TwoWay}"
                                              AutomationProperties.Name="{Binding Loc[MarketTag]}">
                                        <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <ComboBox Grid.Column="4" Classes="cfp-input" HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding MarketActivityOptions}"
                                              SelectedItem="{Binding SelectedMarketActivityOption, Mode=TwoWay}"
                                              AutomationProperties.Name="{Binding Loc[ActivityAll]}">
                                        <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>

                            <Grid Grid.Row="1" Margin="24,0,24,24">
                                <ListBox Classes="cfp-list cfp-market-list"
                                         ItemsSource="{Binding VisibleMarketDisplayMods}"
                                         AutomationProperties.Name="{Binding Loc[ModMarket]}">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <VirtualizingStackPanel />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:MarketModItemViewModel" x:CompileBindings="False">
                                            <Button Classes="cfp-market-item"
                                                    HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Stretch"
                                                    Command="{Binding #Root.DataContext.OpenMarketModCommand}"
                                                    CommandParameter="{Binding Manifest}"
                                                    AutomationProperties.Name="{Binding PrimaryName}">
                                                <Grid ColumnDefinitions="36,*,Auto" ColumnSpacing="10">
                                                    <Border Width="32" Height="32" CornerRadius="6"
                                                            Background="{DynamicResource CfSurfaceHoverBrush}">
                                                        <LucideIcon Kind="Package" Size="16"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center" />
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Spacing="2">
                                                        <TextBlock Classes="cfp-row-title" Text="{Binding PrimaryName}" TextTrimming="CharacterEllipsis" />
                                                        <WrapPanel Orientation="Horizontal">
                                                            <TextBlock Classes="cfp-caption"
                                                                       Margin="0,0,10,0"
                                                                       Text="{Binding SecondaryName}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       IsVisible="{Binding HasSecondaryName}" />
                                                            <TextBlock Classes="cfp-caption" Margin="0,0,10,0" Text="{Binding Version}" />
                                                            <TextBlock Classes="cfp-caption" Margin="0,0,10,0" Text="{Binding LoaderId}" />
                                                            <TextBlock Classes="cfp-caption" Text="{Binding SourceName}" />
                                                        </WrapPanel>
                                                        <ItemsControl ItemsSource="{Binding Tags}">
                                                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate><Border Classes="cfp-badge cfp-market-tag" Margin="0,2,6,0"><TextBlock Classes="cfp-caption" Text="{Binding Name}" /></Border></DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                    <LucideIcon Grid.Column="2" Kind="ChevronRight" Size="16"
                                                                Foreground="{DynamicResource CfMutedTextBrush}"
                                                                VerticalAlignment="Center" />
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <TextBlock Margin="24"
                                           Classes="cfp-meta"
                                           Text="{Binding Loc[MarketEmpty]}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"
                                           IsVisible="{Binding VisibleMarketDisplayMods.Count, Converter={x:Static converters:ObjectConverters.Equal}, ConverterParameter={StaticResource Zero}}" />
                            </Grid>
                        </Grid>

                        <ScrollViewer IsVisible="{Binding IsMarketDetail}"
                                      HorizontalContentAlignment="Stretch"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Classes="cfp-workspace" Margin="24" Spacing="16" MaxWidth="1200" HorizontalAlignment="Stretch">
                                <Button Classes="cfp-secondary"
                                        HorizontalAlignment="Left"
                                        Command="{Binding BackToMarketCommand}"
                                        AutomationProperties.Name="{Binding Loc[BackToMarket]}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <LucideIcon Kind="ArrowLeft" Size="16" />
                                        <TextBlock Text="{Binding Loc[BackToMarket]}" />
                                    </StackPanel>
                                </Button>
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="cfp-page-title" Text="{Binding SelectedMarketModDisplay.PrimaryName}" TextWrapping="Wrap" />
                                        <TextBlock Classes="cfp-meta"
                                                   Text="{Binding SelectedMarketModDisplay.SecondaryName}"
                                                   TextWrapping="Wrap"
                                                   IsVisible="{Binding SelectedMarketModDisplay.HasSecondaryName}" />
                                        <WrapPanel Orientation="Horizontal">
                                            <TextBlock Classes="cfp-meta" Margin="0,0,12,0" Text="{Binding SelectedMarketModDisplay.Version}" />
                                            <TextBlock Classes="cfp-meta" Margin="0,0,12,0" Text="{Binding SelectedMarketModDisplay.LoaderId}" />
                                            <TextBlock Classes="cfp-meta" Text="{Binding SelectedMarketModDisplay.SourceName}" />
                                        </WrapPanel>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Classes="cfp-primary"
                                            Click="OpenMarketInstallDialog"
                                            AutomationProperties.Name="{Binding Loc[InstallModTitle]}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <LucideIcon Kind="PackagePlus" Size="16" />
                                            <TextBlock Text="{Binding Loc[Install]}" />
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <WrapPanel Classes="cfp-mod-detail-actions"
                                           Orientation="Horizontal"
                                           IsVisible="{Binding HasSelectedMarketModInstallation}">
                                    <Button Classes="cfp-secondary"
                                            Margin="0,0,8,8"
                                            Command="{Binding RepairSelectedMarketModCommand}"
                                            IsVisible="{Binding CanReinstallSelectedMarketMod}"
                                            AutomationProperties.Name="{Binding Loc[ReinstallMod]}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <LucideIcon Kind="RefreshCw" Size="15" />
                                            <TextBlock Text="{Binding Loc[ReinstallMod]}" />
                                        </StackPanel>
                                    </Button>
                                    <Button Classes="cfp-secondary"
                                            Margin="0,0,8,8"
                                            Click="OpenSelectedMarketModFolder"
                                            AutomationProperties.Name="{Binding Loc[OpenFolder]}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <LucideIcon Kind="FolderOpen" Size="15" />
                                            <TextBlock Text="{Binding Loc[OpenFolder]}" />
                                        </StackPanel>
                                    </Button>
                                    <Button Classes="cfp-secondary"
                                            Margin="0,0,8,8"
                                            Command="{Binding OpenSelectedModLogsCommand}"
                                            AutomationProperties.Name="{Binding Loc[OpenLogs]}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <LucideIcon Kind="FileText" Size="15" />
                                            <TextBlock Text="{Binding Loc[OpenLogs]}" />
                                        </StackPanel>
                                    </Button>
                                    <Button Classes="cfp-secondary"
                                            Margin="0,0,8,8"
                                            Click="OpenSelectedModGlobalSettings"
                                            IsVisible="{Binding CanAccessSelectedModGlobalSettings}"
                                            AutomationProperties.Name="{Binding Loc[GlobalSettings]}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <LucideIcon Kind="Settings2" Size="15" />
                                            <TextBlock Text="{Binding Loc[GlobalSettings]}" />
                                        </StackPanel>
                                    </Button>
                                    <Button Classes="cfp-danger"
                                            Margin="0,0,8,8"
                                            Click="ConfirmDeleteSelectedModGlobalSettings"
                                            IsVisible="{Binding HasSelectedModGlobalSettings}"
                                            AutomationProperties.Name="{Binding Loc[DeleteGlobalSettings]}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <LucideIcon Kind="Trash2" Size="15" />
                                            <TextBlock Text="{Binding Loc[DeleteGlobalSettings]}" />
                                        </StackPanel>
                                    </Button>
                                </WrapPanel>

                                <Border Classes="cfp-card" IsVisible="{Binding SelectedMarketModDisplay.HasPrimaryDescription}">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="{Binding SelectedMarketModDisplay.PrimaryDescription}" TextWrapping="Wrap" />
                                        <StackPanel Spacing="4" IsVisible="{Binding SelectedMarketModDisplay.HasSecondaryDescription}">
                                            <TextBlock Classes="cfp-row-title" Text="{Binding Loc[OfficialEnglishDescription]}" />
                                            <TextBlock Classes="cfp-meta"
                                                       Text="{Binding SelectedMarketModDisplay.SecondaryDescription}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Classes="cfp-card cfp-mod-content-card">
                                    <StackPanel Spacing="12">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                            <TextBlock Classes="cfp-section-title"
                                                       Text="{Binding Loc[Readme]}" />
                                            <TextBlock Grid.Column="1"
                                                       Classes="cfp-caption"
                                                       Text="{Binding SelectedModContentStatusText}" />
                                        </Grid>
                                        <ProgressBar IsIndeterminate="True"
                                                     IsVisible="{Binding IsLoadingSelectedModContent}" />
                                        <TextBlock Classes="cfp-caption"
                                                   Foreground="{DynamicResource CfErrorBrush}"
                                                   Text="{Binding SelectedModContentError}"
                                                   TextWrapping="Wrap"
                                                   IsVisible="{Binding HasSelectedModContentError}" />
                                        <mv:MarkdownViewer Markdown="{Binding SelectedModReadmeMarkdown}"
                                                           IsVisible="{Binding HasSelectedModReadme}" />
                                    </StackPanel>
                                </Border>

                                <Border Classes="cfp-card cfp-mod-content-card"
                                        IsVisible="{Binding HasSelectedModReleaseNotes}">
                                    <StackPanel Spacing="12">
                                        <TextBlock Classes="cfp-section-title"
                                                   Text="{Binding Loc[LatestReleaseNotes]}" />
                                        <mv:MarkdownViewer Markdown="{Binding SelectedModReleaseNotesMarkdown}" />
                                    </StackPanel>
                                </Border>

                                <Border Classes="cfp-card">
                                    <StackPanel Spacing="12">
                                        <Grid ColumnDefinitions="140,*"><TextBlock Classes="cfp-row-title" Text="{Binding Loc[Authors]}" /><ItemsControl Grid.Column="1" ItemsSource="{Binding SelectedMarketModDisplay.Authors}"><ItemsControl.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" TextWrapping="Wrap" /></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></Grid>
                                        <Grid ColumnDefinitions="140,*"><TextBlock Classes="cfp-row-title" Text="{Binding Loc[Tags]}" /><ItemsControl Grid.Column="1" ItemsSource="{Binding SelectedMarketModDisplay.Tags}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate><Border Classes="cfp-badge cfp-market-tag" Margin="0,0,6,4"><TextBlock Classes="cfp-caption" Text="{Binding Name}" /></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></Grid>
                                        <Grid ColumnDefinitions="140,*"><TextBlock Classes="cfp-row-title" Text="{Binding Loc[Integrations]}" /><ItemsControl Grid.Column="1" ItemsSource="{Binding SelectedMarketModDisplay.Integrations}"><ItemsControl.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" TextWrapping="Wrap" /></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></Grid>
                                        <Grid ColumnDefinitions="140,*"><TextBlock Classes="cfp-row-title" Text="{Binding Loc[SupportedBuilds]}" /><ItemsControl Grid.Column="1" ItemsSource="{Binding SelectedMarketModDisplay.SupportedBuildIds}"><ItemsControl.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" TextWrapping="Wrap" /></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></Grid>
                                        <Grid ColumnDefinitions="140,*"><TextBlock Classes="cfp-row-title" Text="{Binding Loc[Dependencies]}" /><ItemsControl Grid.Column="1" ItemsSource="{Binding SelectedMarketModDisplay.Dependencies}"><ItemsControl.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" TextWrapping="Wrap" /></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></Grid>
                                        <Grid ColumnDefinitions="140,*" IsVisible="{Binding SelectedMarketModDisplay.HasRepositoryUrl}"><TextBlock Classes="cfp-row-title" Text="{Binding Loc[Repository]}" /><Button Grid.Column="1" Classes="cfp-link" Tag="{Binding SelectedMarketModDisplay.RepositoryUrl}" Click="OpenExternalUrl" AutomationProperties.Name="{Binding Loc[Repository]}"><TextBlock Text="{Binding SelectedMarketModDisplay.RepositoryUrl}" TextWrapping="Wrap" /></Button></Grid>
                                        <Grid ColumnDefinitions="140,*" IsVisible="{Binding SelectedMarketModDisplay.HasIssuesUrl}"><TextBlock Classes="cfp-row-title" Text="{Binding Loc[Issues]}" /><Button Grid.Column="1" Classes="cfp-link" Tag="{Binding SelectedMarketModDisplay.IssuesUrl}" Click="OpenExternalUrl" AutomationProperties.Name="{Binding Loc[Issues]}"><TextBlock Text="{Binding SelectedMarketModDisplay.IssuesUrl}" TextWrapping="Wrap" /></Button></Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <ScrollViewer Grid.Column="1"
                                  IsVisible="{Binding IsDownloadQueueSection}"
                                  HorizontalContentAlignment="Stretch"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Classes="cfp-workspace"
                                    Margin="24"
                                    Spacing="16"
                                    MaxWidth="1200"
                                    HorizontalAlignment="Stretch">
                            <StackPanel Spacing="4">
                                <TextBlock Classes="cfp-page-title" Text="{Binding Loc[DownloadQueue]}" />
                                <TextBlock Classes="cfp-meta"
                                           Text="{Binding Loc[DownloadQueueHint]}"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <ItemsControl ItemsSource="{Binding DownloadQueueGroups}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:DownloadQueueGroupItemViewModel">
                                            <Border Classes="cfp-card" Margin="0,0,0,8">
                                                <StackPanel Spacing="8">
                                                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                                        <StackPanel Spacing="4">
                                                            <TextBlock Classes="cfp-row-title"
                                                                       Text="{Binding Name}"
                                                                       TextWrapping="Wrap" />
                                                            <TextBlock Classes="cfp-caption">
                                                                <TextBlock.TextWrapping>Wrap</TextBlock.TextWrapping>
                                                                <TextBlock.Inlines>
                                                                    <Run Text="{Binding #Root.DataContext.Loc[QueueTarget]}" />
                                                                    <Run Text=": " />
                                                                    <Run Text="{Binding TargetInstanceName}" />
                                                                    <Run Text=" · " />
                                                                    <Run Text="{Binding StageText}" />
                                                                </TextBlock.Inlines>
                                                            </TextBlock>
                                                        </StackPanel>
                                                        <Button Grid.Column="1"
                                                                Classes="cfp-secondary cfp-icon"
                                                                Width="44"
                                                                Height="44"
                                                                Command="{Binding #Root.DataContext.RetryQueuedDownloadCommand}"
                                                                CommandParameter="{Binding Id}"
                                                                ToolTip.Tip="{Binding #Root.DataContext.Loc[QueueRetry]}"
                                                                AutomationProperties.Name="{Binding #Root.DataContext.Loc[QueueRetry]}"
                                                                IsVisible="{Binding CanRetry}"
                                                                Content="{LucideIconContent RotateCcw, 16}" />
                                                        <Button Grid.Column="2"
                                                                Classes="cfp-secondary cfp-icon"
                                                                Width="44"
                                                                Height="44"
                                                                Command="{Binding #Root.DataContext.CancelQueuedDownloadCommand}"
                                                                CommandParameter="{Binding Id}"
                                                                ToolTip.Tip="{Binding #Root.DataContext.Loc[Cancel]}"
                                                                AutomationProperties.Name="{Binding #Root.DataContext.Loc[Cancel]}"
                                                                IsVisible="{Binding CanCancel}"
                                                                Content="{LucideIconContent X, 16}" />
                                                    </Grid>
                                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                        <ProgressBar Minimum="0"
                                                                     Maximum="1"
                                                                     Value="{Binding Progress}"
                                                                     VerticalAlignment="Center" />
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                                            <TextBlock Classes="cfp-caption" Text="{Binding ProgressText}" />
                                                            <TextBlock Classes="cfp-caption" Text="{Binding SpeedText}" />
                                                        </StackPanel>
                                                    </Grid>
                                                    <TextBlock Classes="cfp-caption"
                                                               Foreground="{DynamicResource CfErrorBrush}"
                                                               Text="{Binding Error}"
                                                               TextWrapping="Wrap"
                                                               IsVisible="{Binding HasError}" />
                                                    <Expander IsExpanded="{Binding IsExpanded, Mode=TwoWay}">
                                                        <Expander.Header>
                                                            <TextBlock Classes="cfp-caption"
                                                                       Text="{Binding #Root.DataContext.Loc[QueueDetails]}" />
                                                        </Expander.Header>
                                                        <ItemsControl ItemsSource="{Binding Items}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate x:DataType="vm:DownloadQueueItemViewModel">
                                                                    <Grid ColumnDefinitions="*,Auto"
                                                                          ColumnSpacing="12"
                                                                          Margin="0,4">
                                                                        <StackPanel Spacing="4">
                                                                            <TextBlock Text="{Binding Name}"
                                                                                       TextWrapping="Wrap" />
                                                                            <TextBlock Classes="cfp-caption">
                                                                                <TextBlock.TextWrapping>Wrap</TextBlock.TextWrapping>
                                                                                <TextBlock.Inlines>
                                                                                    <Run Text="{Binding Version}" />
                                                                                    <Run Text=" · " />
                                                                                    <Run Text="{Binding StageText}" />
                                                                                </TextBlock.Inlines>
                                                                            </TextBlock>
                                                                            <TextBlock Classes="cfp-caption"
                                                                                       Foreground="{DynamicResource CfErrorBrush}"
                                                                                       Text="{Binding Error}"
                                                                                       TextWrapping="Wrap"
                                                                                       IsVisible="{Binding HasError}" />
                                                                        </StackPanel>
                                                                        <StackPanel Grid.Column="1"
                                                                                    HorizontalAlignment="Right"
                                                                                    Spacing="4">
                                                                            <TextBlock Classes="cfp-caption"
                                                                                       Text="{Binding ProgressText}"
                                                                                       TextAlignment="Right" />
                                                                            <TextBlock Classes="cfp-caption"
                                                                                       Text="{Binding SpeedText}"
                                                                                       TextAlignment="Right" />
                                                                            <TextBlock Classes="cfp-caption"
                                                                                       Text="{Binding RetryText}"
                                                                                       TextAlignment="Right"
                                                                                       IsVisible="{Binding HasRetries}" />
                                                                        </StackPanel>
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Expander>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <StackPanel Spacing="12"
                                            HorizontalAlignment="Center"
                                            Margin="24"
                                            IsVisible="{Binding DownloadQueueGroups.Count, Converter={x:Static converters:ObjectConverters.Equal}, ConverterParameter={StaticResource Zero}}">
                                    <TextBlock Classes="cfp-meta"
                                               MaxWidth="480"
                                               Text="{Binding Loc[DownloadQueueEmpty]}"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap" />
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                Spacing="8">
                                        <Button Classes="cfp-secondary"
                                                Command="{Binding SelectDownloadSectionCommand}"
                                                CommandParameter="GameVersions"
                                                Content="{Binding Loc[GameVersions]}" />
                                        <Button Classes="cfp-secondary"
                                                Command="{Binding SelectDownloadSectionCommand}"
                                                CommandParameter="ModMarket"
                                                Content="{Binding Loc[ModMarket]}" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- Settings -->
            <Grid Classes="cfp-page" IsVisible="{Binding IsSettingsPage}">
                <ScrollViewer
                              HorizontalContentAlignment="Stretch"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Classes="cfp-workspace cfp-settings-workspace"
                                Margin="24"
                                Spacing="16"
                                MaxWidth="1200"
                                HorizontalAlignment="Stretch">
                        <Border Classes="cfp-card">
                            <StackPanel Spacing="12">
                                <TextBlock Classes="cfp-section-title" Text="{Binding Loc[VersionRoot]}" />
                                <u:PathPicker UsePickerType="OpenFolder"
                                              Title="{Binding Loc[SelectVersionRootTitle]}"
                                              SelectedPathsText="{Binding VersionRoot, Mode=TwoWay}"
                                              SuggestedStartPath="{Binding VersionRoot}"
                                              Command="{Binding ApplyVersionRootCommand}"
                                              IsOmitCommandOnCancel="True"
                                              MinHeight="44"
                                              AutomationProperties.Name="{Binding Loc[VersionRoot]}">
                                    <u:PathPicker.Styles>
                                        <Style Selector="TextBox">
                                            <Setter Property="AutomationProperties.Name"
                                                    Value="{Binding Loc[VersionRoot]}" />
                                        </Style>
                                    </u:PathPicker.Styles>
                                    <u:PathPicker.ButtonContent>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <LucideIcon Kind="FolderOpen" Size="16" />
                                            <TextBlock Text="{Binding Loc[Browse]}" />
                                        </StackPanel>
                                    </u:PathPicker.ButtonContent>
                                </u:PathPicker>
                            </StackPanel>
                        </Border>

                        <Border Classes="cfp-card">
                            <Grid ColumnDefinitions="*,16,*">
                                <StackPanel Grid.Column="0" Spacing="8">
                                    <TextBlock Classes="cfp-row-title" Text="{Binding Loc[Language]}" />
                                    <ComboBox Classes="cfp-input"
                                              ItemsSource="{Binding LanguageOptions}"
                                              SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"
                                              AutomationProperties.Name="{Binding Loc[Language]}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Name}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="8">
                                    <TextBlock Classes="cfp-row-title" Text="{Binding Loc[Theme]}" />
                                    <ComboBox Classes="cfp-input"
                                              ItemsSource="{Binding ThemeOptions}"
                                              SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"
                                              AutomationProperties.Name="{Binding Loc[Theme]}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Name}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Classes="cfp-card">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <StackPanel Spacing="3">
                                    <TextBlock Classes="cfp-row-title" Text="{Binding Loc[OfflineMode]}" />
                                    <TextBlock Classes="cfp-caption"
                                               Text="{Binding Loc[OfflineModeHint]}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <CheckBox Grid.Column="1"
                                          VerticalAlignment="Center"
                                          Content="{Binding Loc[OfflineMode]}"
                                          IsChecked="{Binding IsOfflineMode, Mode=TwoWay}" />
                            </Grid>
                        </Border>
                        <Border Classes="cfp-card">
                            <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <StackPanel Spacing="3">
                                        <TextBlock Classes="cfp-row-title" Text="{Binding Loc[ApplicationUpdates]}" />
                                        <TextBlock Classes="cfp-caption"
                                                   Text="{Binding Loc[ApplicationUpdatesHint]}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <CheckBox Grid.Column="1"
                                              VerticalAlignment="Center"
                                              Content="{Binding Loc[CheckForUpdates]}"
                                              IsChecked="{Binding IsAutomaticUpdateCheckEnabled, Mode=TwoWay}" />
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <TextBlock Classes="cfp-meta"
                                               Text="{Binding ApplicationUpdateStatus}"
                                               VerticalAlignment="Center" />
                                    <Button Grid.Column="1"
                                            Classes="cfp-secondary"
                                            Click="OnCheckForApplicationUpdatesClick"
                                            IsEnabled="{Binding IsCheckingForApplicationUpdates, Converter={x:Static converters:BoolConverters.Not}}"
                                            AutomationProperties.Name="{Binding Loc[CheckNow]}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <LucideIcon Kind="RefreshCw" Size="15" />
                                            <TextBlock Text="{Binding Loc[CheckNow]}" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border Classes="cfp-card">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <StackPanel Spacing="3">
                                    <TextBlock Classes="cfp-row-title" Text="{Binding Loc[ProtocolRegistration]}" />
                                    <TextBlock Classes="cfp-caption"
                                               Text="{Binding Loc[ProtocolRegistrationHint]}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Classes="cfp-row-title"
                                           Text="{Binding ProtocolRegistrationStatus}"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <Border Classes="cfp-card cfp-github-route-card">
                            <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <StackPanel Spacing="3">
                                        <TextBlock Classes="cfp-row-title" Text="{Binding Loc[GitHubRoute]}" />
                                        <TextBlock Classes="cfp-caption" Text="{Binding Loc[GitHubRouteHint]}" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <ComboBox Grid.Column="1" Width="190" Classes="cfp-input" ItemsSource="{Binding GitHubRouteOptions}" SelectedItem="{Binding SelectedGitHubRoute, Mode=TwoWay}" AutomationProperties.Name="{Binding Loc[GitHubRoute]}">
                                        <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate>
                                    </ComboBox>
                                </Grid>
                                <Grid ColumnDefinitions="*,*,Auto" ColumnSpacing="8">
                                    <Border Classes="cfp-latency-result"><StackPanel Spacing="2"><TextBlock Classes="cfp-caption" Text="{Binding Loc[GitHubDirect]}" /><TextBlock Classes="cfp-row-title" Text="{Binding GitHubDirectLatency}" /></StackPanel></Border>
                                    <Border Grid.Column="1" Classes="cfp-latency-result"><StackPanel Spacing="2"><TextBlock Classes="cfp-caption" Text="{Binding Loc[GitHubMirror]}" /><TextBlock Classes="cfp-row-title" Text="{Binding GitHubMirrorLatency}" /></StackPanel></Border>
                                    <Button Grid.Column="2" Classes="cfp-secondary" Command="{Binding TestGitHubLatencyCommand}" IsEnabled="{Binding IsTestingGitHubLatency, Converter={x:Static converters:BoolConverters.Not}}"><StackPanel Orientation="Horizontal" Spacing="6"><LucideIcon Kind="Gauge" Size="15" /><TextBlock Text="{Binding Loc[TestLatency]}" /></StackPanel></Button>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Classes="cfp-card">
                            <StackPanel Spacing="6">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <StackPanel Spacing="2">
                                        <TextBlock Classes="cfp-section-title" Text="{Binding Loc[HKModLinks]}" />
                                        <TextBlock Classes="cfp-caption" Text="{Binding Loc[HKModLinksHint]}" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                               Classes="cfp-row-title"
                                               Text="{Binding OfficialModCatalogStatus}"
                                               VerticalAlignment="Center" />
                                </Grid>
                                <TextBlock Classes="cfp-meta"
                                           Text="{Binding OfficialModCatalogSummary}"
                                           TextWrapping="Wrap" />
                                <TextBlock Classes="cfp-meta"
                                            Text="{Binding OfficialModCatalogError}"
                                            Foreground="{DynamicResource CfErrorBrush}"
                                            TextWrapping="Wrap"
                                           IsVisible="{Binding OfficialModCatalogError, Converter={x:Static converters:StringConverters.IsNotNullOrEmpty}}" />
                            </StackPanel>
                        </Border>

                        <Border Classes="cfp-card">
                            <StackPanel Spacing="12">
                                <TextBlock Classes="cfp-section-title" Text="{Binding Loc[CustomModLinks]}" />
                                <TextBlock Classes="cfp-caption"
                                           Text="{Binding Loc[CustomModLinksHint]}"
                                           TextWrapping="Wrap" />
                                <TextBox Classes="cfp-input"
                                         Text="{Binding CustomModLinksUrl, Mode=TwoWay}"
                                         PlaceholderText="https://example.invalid/ModLinks.xml"
                                         AutomationProperties.Name="{Binding Loc[CustomModLinks]}" />
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                    <ComboBox Classes="cfp-input"
                                              ItemsSource="{Binding CustomModLinksBuildOptions}"
                                              SelectedItem="{Binding SelectedCustomModLinksBuild, Mode=TwoWay}"
                                              AutomationProperties.Name="{Binding Loc[MarketBuild]}">
                                        <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <ComboBox Grid.Column="1"
                                              Classes="cfp-input"
                                              ItemsSource="{Binding CustomModLinksLoaderOptions}"
                                              SelectedItem="{Binding SelectedCustomModLinksLoader, Mode=TwoWay}"
                                              AutomationProperties.Name="{Binding Loc[MarketLoader]}">
                                        <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate>
                                    </ComboBox>
                                </Grid>
                                <Button Classes="cfp-accent"
                                        Command="{Binding SaveCustomModLinksCommand}"
                                        HorizontalAlignment="Right">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <LucideIcon Kind="Save" Size="16" />
                                        <TextBlock Text="{Binding Loc[Save]}" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <Border Classes="cfp-card">
                            <StackPanel Spacing="12">
                                <TextBlock Classes="cfp-section-title" Text="{Binding Loc[CustomCatalogSources]}" />
                                <TextBox Classes="cfp-input"
                                         Text="{Binding CustomSourcesText, Mode=TwoWay}"
                                         AcceptsReturn="True"
                                         MinHeight="120"
                                         AutomationProperties.Name="{Binding Loc[CustomCatalogSources]}"
                                         TextWrapping="NoWrap" />
                                <Button Classes="cfp-accent"
                                        Command="{Binding SaveCustomSourcesCommand}"
                                        HorizontalAlignment="Right">
                                    <Button.IsEnabled>
                                        <MultiBinding Converter="{x:Static converters:BoolConverters.And}">
                                            <Binding Path="IsBusy" Converter="{x:Static converters:BoolConverters.Not}" />
                                            <Binding Path="IsGameRunning" Converter="{x:Static converters:BoolConverters.Not}" />
                                        </MultiBinding>
                                    </Button.IsEnabled>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <LucideIcon Kind="Save" Size="16" />
                                        <TextBlock Text="{Binding Loc[Save]}" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
        </u:LoadingContainer>
        <Button Grid.Row="2" Classes="cfp-download-fab cfp-primary" Width="44" Height="44" Margin="16" HorizontalAlignment="Right" VerticalAlignment="Bottom" Command="{Binding OpenDownloadQueueCommand}" ToolTip.Tip="{Binding ActiveDownloadSummary}" AutomationProperties.Name="{Binding Loc[DownloadQueue]}" IsVisible="{Binding HasActiveDownloads}" Content="{LucideIconContent Download, 18}" />
        <u:OverlayDialogHost x:Name="MainOverlayDialogHost"
                             Grid.RowSpan="3"
                             HostId="Crystalfly.Main" />
    </Grid>
</Window>
