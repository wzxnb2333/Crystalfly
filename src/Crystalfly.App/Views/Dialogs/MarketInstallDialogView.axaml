<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Crystalfly.App.ViewModels.Dialogs"
             xmlns:converters="using:Avalonia.Data.Converters"
             xmlns:u="https://irihi.tech/ursa"
             x:Class="Crystalfly.App.Views.Dialogs.MarketInstallDialogView"
             x:DataType="vm:MarketInstallDialogViewModel"
             Width="600"
             MinWidth="480"
             MaxHeight="560">
    <UserControl.KeyBindings>
        <KeyBinding Gesture="Escape" Command="{Binding CancelCommand}" />
    </UserControl.KeyBindings>

    <Grid Margin="24"
          RowDefinitions="Auto,Auto,*,Auto,Auto"
          RowSpacing="12">
        <TextBlock Classes="cfp-section-title"
                   Text="{Binding Main.Loc[InstallToInstance]}"
                   TextWrapping="Wrap" />
        <TextBlock Grid.Row="1"
                   Classes="cfp-meta"
                   Text="{Binding ModName}"
                   TextWrapping="Wrap" />
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="8">
                <ItemsControl ItemsSource="{Binding Targets}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:MarketInstallTargetOptionViewModel">
                            <RadioButton GroupName="market-install-target"
                                         Content="{Binding}"
                                         IsEnabled="{Binding IsAvailable}"
                                         IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                         HorizontalContentAlignment="Stretch"
                                         Padding="12"
                                         MinHeight="72"
                                         Margin="0,0,0,8"
                                         u:FocusHelper.DialogFocusHint="{Binding IsSelected}"
                                         AutomationProperties.Name="{Binding DisplayName}">
                                <RadioButton.ContentTemplate>
                                    <DataTemplate x:DataType="vm:MarketInstallTargetOptionViewModel">
                                        <StackPanel Spacing="3">
                                            <TextBlock Classes="cfp-row-title"
                                                       Text="{Binding DisplayName}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Classes="cfp-meta">
                                                <TextBlock.Inlines>
                                                    <Run Text="{Binding BuildDisplayName}" />
                                                    <Run Text=" · " />
                                                    <Run Text="{Binding LoaderDisplayName}" />
                                                </TextBlock.Inlines>
                                            </TextBlock>
                                            <TextBlock Classes="cfp-caption"
                                                       Text="{Binding StatusText}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </DataTemplate>
                                </RadioButton.ContentTemplate>
                            </RadioButton>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Classes="cfp-meta"
                           Text="{Binding Main.Loc[NoInstallTargets]}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           IsVisible="{Binding HasTargets, Converter={x:Static converters:BoolConverters.Not}}" />
            </StackPanel>
        </ScrollViewer>
        <TextBlock Grid.Row="3"
                   Foreground="{DynamicResource CfErrorBrush}"
                   Text="{Binding DialogError}"
                   TextWrapping="Wrap"
                   IsVisible="{Binding DialogError, Converter={x:Static converters:StringConverters.IsNotNullOrEmpty}}" />
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
            <Button Classes="cfp-secondary"
                    Command="{Binding CancelCommand}"
                    Content="{Binding Main.Loc[Cancel]}"
                    MinWidth="96"
                    AutomationProperties.Name="{Binding Main.Loc[Cancel]}" />
            <Button Classes="cfp-primary"
                    Command="{Binding InstallCommand}"
                    Content="{Binding Main.Loc[InstallSelectedMod]}"
                    MinWidth="128"
                    AutomationProperties.Name="{Binding Main.Loc[InstallSelectedMod]}" />
        </StackPanel>
    </Grid>
</UserControl>
