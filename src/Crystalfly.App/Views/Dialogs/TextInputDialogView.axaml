<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Crystalfly.App.ViewModels.Dialogs"
             xmlns:u="https://irihi.tech/ursa"
             x:Class="Crystalfly.App.Views.Dialogs.TextInputDialogView"
             x:DataType="vm:TextInputDialogViewModel"
             Width="480"
             MinWidth="400"
             MaxWidth="560">
    <UserControl.KeyBindings>
        <KeyBinding Gesture="Enter" Command="{Binding ConfirmCommand}" />
        <KeyBinding Gesture="Escape" Command="{Binding CancelCommand}" />
    </UserControl.KeyBindings>

    <Grid Margin="24" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="16">
        <TextBlock Classes="cfp-section-title"
                   Text="{Binding Title}"
                   TextWrapping="Wrap" />
        <TextBlock Grid.Row="1"
                   Text="{Binding Message}"
                   TextWrapping="Wrap" />
        <TextBox Grid.Row="2"
                 Text="{Binding Text, Mode=TwoWay}"
                 PlaceholderText="{Binding Placeholder}"
                 MinWidth="320"
                 u:FocusHelper.DialogFocusHint="True"
                 AutomationProperties.Name="{Binding Placeholder}" />
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
            <Button Classes="cfp-secondary"
                    Command="{Binding CancelCommand}"
                    Content="{Binding CancelText}"
                    MinWidth="96"
                    AutomationProperties.Name="{Binding CancelText}" />
            <Button Classes="cfp-primary"
                    Command="{Binding ConfirmCommand}"
                    Content="{Binding ConfirmText}"
                    IsEnabled="{Binding CanConfirm}"
                    MinWidth="96"
                    AutomationProperties.Name="{Binding ConfirmText}" />
        </StackPanel>
    </Grid>
</UserControl>
