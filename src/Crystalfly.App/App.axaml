<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Crystalfly.App.App"
             xmlns:local="using:Crystalfly.App"
             xmlns:semi="https://irihi.tech/semi"
             RequestedThemeVariant="Default">
    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <semi:SemiTheme />
        <semi:UrsaSemiTheme />
        <StyleInclude Source="avares://Crystalfly.App/Styles/CrystalflyTheme.axaml" />
    </Application.Styles>
</Application>
