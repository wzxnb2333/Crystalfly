<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Crystalfly.App.App"
             xmlns:local="using:Crystalfly.App"
             RequestedThemeVariant="Default">
    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Crystalfly.App/Styles/CrystalflyTheme.axaml" />
    </Application.Styles>
</Application>
